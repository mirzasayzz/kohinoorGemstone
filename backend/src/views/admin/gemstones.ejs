<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
    <style>
        * { font-family: 'Segoe UI', system-ui, sans-serif; }
        body { background: linear-gradient(135deg, #0f2027, #203a43, #2c5364); }
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: #0f2027; }
        ::-webkit-scrollbar-thumb { background: #d4af37; border-radius: 3px; }
        .sidebar { background: linear-gradient(180deg, #0f2027, #0a1a1f); }
        .nav-link { transition: all 0.2s ease; border-left: 3px solid transparent; }
        .nav-link:hover, .nav-link.active { background: rgba(212, 175, 55, 0.1); border-left-color: #d4af37; }
        .card { background: rgba(15, 32, 39, 0.8); border: 1px solid rgba(212, 175, 55, 0.15); transition: all 0.3s ease; }
        .card:hover { transform: translateY(-6px); border-color: rgba(212, 175, 55, 0.5); box-shadow: 0 20px 40px rgba(212, 175, 55, 0.1); }
        .text-gold { color: #d4af37; }
        .border-gold { border-color: rgba(212, 175, 55, 0.3); }
        .btn-gold { background: linear-gradient(135deg, #d4af37, #c9a227); color: #0f2027; }
        .btn-gold:hover { transform: translateY(-2px); box-shadow: 0 10px 25px rgba(212, 175, 55, 0.3); }
        .input-glow { background: rgba(32, 58, 67, 0.6); border: 1px solid rgba(212, 175, 55, 0.2); color: #fff; transition: all 0.3s ease; }
        .input-glow:hover { border-color: rgba(212, 175, 55, 0.5); box-shadow: 0 0 15px rgba(212, 175, 55, 0.2); }
        .input-glow:focus { outline: none; border-color: #d4af37; box-shadow: 0 0 20px rgba(212, 175, 55, 0.4); }
        .kingdom-title { background: linear-gradient(90deg, #d4af37, #f4d03f, #d4af37); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; animation: shimmer 3s infinite; background-size: 200% auto; }
        @keyframes shimmer { 0%,100% { background-position: 0% center; } 50% { background-position: 200% center; } }
        .gemstone-img { object-fit: cover; object-position: center; width: 100%; height: 100%; }
    </style>
</head>
<body class="text-white min-h-screen">
    <% const activePage = 'gemstones'; %>
    <%- include('partials/sidebar') %>

    <div class="lg:ml-64 min-h-screen">
        <header class="sticky top-0 z-30 h-16 bg-[#0f2027]/95 backdrop-blur border-b border-gold px-4">
            <div class="h-full flex items-center justify-between">
                <div class="flex items-center space-x-2 sm:space-x-4 min-w-0">
                    <button onclick="toggleSidebar()" class="lg:hidden p-2 hover:bg-white/10 rounded flex-shrink-0">
                        <i data-lucide="menu" class="w-5 h-5"></i>
                    </button>
                    <h1 class="text-base sm:text-lg font-semibold truncate">Gemstones</h1>
                    <span class="hidden sm:inline-flex items-center px-2 py-1 bg-gold/20 rounded text-xs text-gold flex-shrink-0"><%= gemstones.length %></span>
                </div>
                <a href="/admin/gemstones/add" class="btn-gold flex items-center px-3 py-2 rounded-lg text-xs sm:text-sm font-medium transition-all flex-shrink-0">
                    <i data-lucide="plus" class="w-4 h-4 sm:mr-1"></i><span class="hidden sm:inline">Add</span>
                </a>
            </div>
        </header>

        <main class="p-4 lg:p-6 space-y-6">
            <% if (typeof error !== 'undefined' && error) { %>
            <div class="p-4 bg-red-500/10 border border-red-500/30 rounded-lg flex items-center">
                <i data-lucide="alert-circle" class="w-5 h-5 text-red-400 mr-3"></i>
                <span class="text-red-400"><%= error %></span>
            </div>
            <% } %>
            <% if (typeof success !== 'undefined' && success) { %>
            <div class="p-4 bg-green-500/10 border border-green-500/30 rounded-lg flex items-center">
                <i data-lucide="check-circle" class="w-5 h-5 text-green-400 mr-3"></i>
                <span class="text-green-400"><%= success %></span>
            </div>
            <% } %>

            <!-- Search Bar -->
            <div class="card p-4 hover:transform-none">
                <div class="flex flex-col sm:flex-row gap-4">
                    <div class="flex-1 relative">
                        <i data-lucide="search" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gold"></i>
                        <input type="text" id="searchInput" placeholder="Search by name..." class="input-glow w-full pl-10 pr-4 py-3 rounded-lg text-sm" oninput="filterGemstones()">
                    </div>
                    <select id="categoryFilter" class="input-glow px-4 py-3 rounded-lg text-sm" onchange="filterGemstones()">
                        <option value="">All Categories</option>
                        <option value="Ruby">Ruby</option>
                        <option value="Emerald">Emerald</option>
                        <option value="Sapphire">Sapphire</option>
                        <option value="Diamond">Diamond</option>
                        <option value="Pearl">Pearl</option>
                        <option value="Topaz">Topaz</option>
                        <option value="Other">Other</option>
                    </select>
                </div>
            </div>

            <% if (gemstones.length > 0) { %>
            <!-- Gemstone Grid -->
            <div id="gemstoneGrid" class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-4">
                <% gemstones.forEach(gemstone => { %>
                <div class="gemstone-item card rounded-xl overflow-hidden" data-name="<%= gemstone.name.english.toLowerCase() %>" data-category="<%= gemstone.category %>">
                    <!-- Image -->
                    <div class="relative h-48 bg-gradient-to-br from-[#1a3a47] to-[#0f2027]">
                        <% if (gemstone.images && gemstone.images.length > 0) { %>
                        <img src="<%= gemstone.images[0].url %>" alt="<%= gemstone.name.english %>" class="gemstone-img">
                        <% } else { %>
                        <div class="w-full h-full flex items-center justify-center">
                            <i data-lucide="gem" class="w-16 h-16 text-gold/30"></i>
                        </div>
                        <% } %>
                        <% if (gemstone.trending) { %>
                        <div class="absolute top-3 left-3">
                            <span class="px-2 py-1 bg-gradient-to-r from-orange-500 to-red-500 text-white text-xs font-medium rounded-lg flex items-center shadow-lg">
                                <i data-lucide="trending-up" class="w-3 h-3 mr-1"></i>Trending
                            </span>
                        </div>
                        <% } %>
                        <div class="absolute top-3 right-3">
                            <span class="px-2 py-1 bg-black/60 text-gold text-xs font-medium rounded-lg"><%= gemstone.category %></span>
                        </div>
                    </div>
                    
                    <!-- Content -->
                    <div class="p-4">
                        <div class="flex items-start justify-between gap-2 mb-1">
                            <h3 class="font-semibold text-white"><%= gemstone.name.english %></h3>
                            <% if (gemstone.price || (gemstone.priceRange && (gemstone.priceRange.min || gemstone.priceRange.max))) { %>
                            <span class="px-2.5 py-1 bg-emerald-500 text-white text-sm font-bold rounded-lg whitespace-nowrap">
                                ₹<%= gemstone.price ? gemstone.price.toLocaleString() : (gemstone.priceRange.min ? gemstone.priceRange.min.toLocaleString() : gemstone.priceRange.max.toLocaleString()) %>
                            </span>
                            <% } %>
                        </div>
                        <% if (gemstone.name.urdu) { %>
                        <p class="text-sm text-gray-400 mb-2"><%= gemstone.name.urdu %></p>
                        <% } %>
                        
                        <div class="flex items-center gap-3 text-xs text-gray-400 mb-4">
                            <span class="flex items-center"><i data-lucide="eye" class="w-3 h-3 mr-1"></i><%= gemstone.viewCount || 0 %></span>
                            <% if (gemstone.ratti) { %>
                            <span class="flex items-center"><i data-lucide="scale" class="w-3 h-3 mr-1"></i><%= gemstone.ratti %> Ratti</span>
                            <% } %>
                        </div>
                        
                        <!-- Actions -->
                        <div class="flex items-center gap-2">
                            <a href="/admin/gemstones/edit/<%= gemstone._id %>" class="flex-1 px-2 sm:px-3 py-2 bg-gold/20 hover:bg-gold/30 border border-gold/30 rounded-lg text-xs sm:text-sm text-gold flex items-center justify-center transition-all">
                                <i data-lucide="edit-2" class="w-3 h-3 sm:w-4 sm:h-4 mr-1"></i>Edit
                            </a>
                            <button onclick="deleteGemstone('<%= gemstone._id %>', '<%= gemstone.name.english %>')" class="px-2 sm:px-3 py-2 bg-red-500/20 hover:bg-red-500/30 border border-red-500/30 rounded-lg text-xs sm:text-sm text-red-400 transition-all" title="Delete">
                                <i data-lucide="trash-2" class="w-3 h-3 sm:w-4 sm:h-4"></i>
                            </button>
                        </div>
                    </div>
                </div>
                <% }) %>
            </div>
            
            <div id="noResults" class="hidden text-center py-12">
                <i data-lucide="search-x" class="w-16 h-16 text-gold/30 mx-auto mb-4"></i>
                <p class="text-gray-400">No gemstones found</p>
            </div>
            <% } else { %>
            <!-- Empty State -->
            <div class="card p-12 text-center hover:transform-none">
                <div class="w-20 h-20 bg-gold/10 rounded-full flex items-center justify-center mx-auto mb-4">
                    <i data-lucide="gem" class="w-10 h-10 text-gold"></i>
                </div>
                <h3 class="text-xl font-semibold mb-2 text-gold">No gemstones yet</h3>
                <p class="text-gray-400 mb-6">Start by adding your first gemstone</p>
                <a href="/admin/gemstones/add" class="btn-gold inline-flex items-center px-6 py-3 rounded-lg font-medium transition-all">
                    <i data-lucide="plus" class="w-5 h-5 mr-2"></i>Add First Gemstone
                </a>
            </div>
            <% } %>
        </main>
    </div>

    <script>
        lucide.createIcons();
        
        function toggleSidebar() {
            document.getElementById('sidebar').classList.toggle('-translate-x-full');
            document.getElementById('overlay').classList.toggle('hidden');
        }

        // Instant search filter
        function filterGemstones() {
            const search = document.getElementById('searchInput').value.toLowerCase().trim();
            const category = document.getElementById('categoryFilter').value;
            const items = document.querySelectorAll('.gemstone-item');
            let visibleCount = 0;
            
            items.forEach(item => {
                const name = item.dataset.name;
                const cat = item.dataset.category;
                const matchesSearch = !search || name.includes(search);
                const matchesCategory = !category || cat === category;
                
                if (matchesSearch && matchesCategory) {
                    item.style.display = 'block';
                    visibleCount++;
                } else {
                    item.style.display = 'none';
                }
            });
            
            document.getElementById('noResults').classList.toggle('hidden', visibleCount > 0);
        }

        // Delete gemstone
        async function deleteGemstone(id, name) {
            if (!confirm('Delete "' + name + '"?\n\nThis cannot be undone!')) return;
            
            try {
                // Try DELETE method first
                let res = await fetch('/admin/gemstones/' + id, {
                    method: 'DELETE',
                    headers: { 
                        'Content-Type': 'application/json',
                        'Accept': 'application/json'
                    }
                });
                
                // If DELETE fails, try POST fallback
                if (!res.ok) {
                    res = await fetch('/admin/gemstones/delete/' + id, {
                        method: 'POST',
                        headers: { 
                            'Content-Type': 'application/json',
                            'Accept': 'application/json'
                        }
                    });
                }
                
                if (res.ok) {
                    // Remove the card immediately for better UX
                    const cards = document.querySelectorAll('.gemstone-item');
                    cards.forEach(card => {
                        if (card.querySelector('button[onclick*="' + id + '"]')) {
                            card.remove();
                        }
                    });
                    // Reload to get fresh data
                    window.location.reload();
                } else {
                    let errorMsg = 'Failed to delete';
                    try {
                        const data = await res.json();
                        errorMsg = data.message || data.error || errorMsg;
                    } catch (e) {}
                    alert(errorMsg);
                }
            } catch (err) {
                console.error('Delete error:', err);
                alert('Error deleting gemstone: ' + err.message);
            }
        }
    </script>
</body>
</html>
