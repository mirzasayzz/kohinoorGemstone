<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        dark: { 900: '#0a0a0a', 800: '#111111', 700: '#1a1a1a', 600: '#242424', 500: '#2d2d2d', 400: '#3d3d3d', 300: '#525252', 200: '#737373', 100: '#a3a3a3' }
                    }
                }
            }
        }
    </script>
    <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
    <style>
        * { font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif; }
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: #1a1a1a; }
        ::-webkit-scrollbar-thumb { background: #3d3d3d; border-radius: 3px; }
        .nav-item { transition: all 0.15s ease; }
        .nav-item:hover { background: rgba(255,255,255,0.05); }
        .nav-item.active { background: rgba(255,255,255,0.1); border-right: 2px solid #fff; }
        .card { background: #111111; border: 1px solid #242424; border-radius: 8px; transition: all 0.2s; }
        .card:hover { border-color: #3d3d3d; }
        .input-field { background: #1a1a1a; border: 1px solid #3d3d3d; color: #fff; }
        .input-field:focus { border-color: #525252; outline: none; }
        .input-field::placeholder { color: #737373; }
    </style>
</head>
<body class="bg-dark-900 text-white min-h-screen">
    <div id="overlay" class="fixed inset-0 bg-black/60 z-40 lg:hidden hidden" onclick="toggleSidebar()"></div>
    
    <aside id="sidebar" class="fixed inset-y-0 left-0 z-50 w-64 bg-dark-800 border-r border-dark-600 transform -translate-x-full lg:translate-x-0 transition-transform duration-200">
        <div class="h-16 flex items-center justify-between px-5 border-b border-dark-600">
            <div class="flex items-center space-x-3">
                <div class="w-8 h-8 bg-white rounded-lg flex items-center justify-center">
                    <i data-lucide="gem" class="w-5 h-5 text-dark-900"></i>
                </div>
                <span class="font-semibold text-lg">Kohinoor</span>
            </div>
            <button onclick="toggleSidebar()" class="lg:hidden p-1 hover:bg-dark-600 rounded"><i data-lucide="x" class="w-5 h-5"></i></button>
        </div>
        <nav class="p-3 space-y-1">
            <p class="text-xs text-gray-500 uppercase px-3 py-2">Menu</p>
            <a href="/admin/dashboard" class="nav-link flex items-center px-3 py-2.5 rounded-lg text-sm text-gray-300">
                <i data-lucide="home" class="w-5 h-5 mr-3"></i>Home
            </a>
            <a href="/admin/gemstones" class="nav-link flex items-center px-3 py-2.5 rounded-lg text-sm text-gray-300">
                <i data-lucide="gem" class="w-5 h-5 mr-3"></i>All Gemstones
            </a>
            <a href="/admin/gemstones/add" class="nav-link flex items-center px-3 py-2.5 rounded-lg text-sm text-gray-300">
                <i data-lucide="plus-circle" class="w-5 h-5 mr-3"></i>Add New
            </a>
            <a href="/admin/users" class="nav-link flex items-center px-3 py-2.5 rounded-lg text-sm text-gray-300">
                <i data-lucide="users" class="w-5 h-5 mr-3"></i>Users
            </a>
            <a href="/admin/chats" class="nav-link flex items-center px-3 py-2.5 rounded-lg text-sm text-gray-300">
                <i data-lucide="message-circle" class="w-5 h-5 mr-3"></i>Chats
            </a>
            <% if (user.role === 'super_admin') { %>
            <a href="/admin/admins" class="nav-link flex items-center px-3 py-2.5 rounded-lg text-sm text-gray-300">
                <i data-lucide="shield" class="w-5 h-5 mr-3"></i>Manage Admins
            </a>
            <% } %>
            <p class="text-xs text-gray-500 uppercase px-3 py-2 mt-4">Settings</p>
            <a href="/admin/business" class="nav-link flex items-center px-3 py-2.5 rounded-lg text-sm text-gray-300">
                <i data-lucide="settings" class="w-5 h-5 mr-3"></i>Shop Settings
            </a>
            <a href="/admin/change-password" class="nav-link flex items-center px-3 py-2.5 rounded-lg text-sm text-gray-300">
                <i data-lucide="key" class="w-5 h-5 mr-3"></i>Change Password
            </a>
        </nav>
        <div class="absolute bottom-0 left-0 right-0 p-3 border-t border-dark-600">
            <div class="flex items-center justify-between px-3 py-2">
                <div class="flex items-center space-x-3">
                    <div class="w-8 h-8 bg-dark-500 rounded-full flex items-center justify-center"><i data-lucide="user" class="w-4 h-4 text-dark-100"></i></div>
                    <div><div class="text-sm font-medium"><%= user.name %></div><div class="text-xs text-dark-200"><%= user.role %></div></div>
                </div>
                <a href="/admin/logout" class="p-2 hover:bg-dark-600 rounded-lg text-dark-100 hover:text-red-400" title="Logout"><i data-lucide="log-out" class="w-4 h-4"></i></a>
            </div>
        </div>
    </aside>

    <div class="lg:ml-64 min-h-screen">
        <header class="sticky top-0 z-30 h-16 bg-dark-800/95 backdrop-blur border-b border-dark-600 px-4 lg:px-6">
            <div class="h-full flex items-center justify-between">
                <div class="flex items-center space-x-4">
                    <button onclick="toggleSidebar()" class="lg:hidden p-2 hover:bg-dark-600 rounded-lg"><i data-lucide="menu" class="w-5 h-5"></i></button>
                    <h1 class="text-lg font-semibold">Categories</h1>
                </div>
                <button id="addCategoryBtn" class="flex items-center px-4 py-2 bg-white text-dark-900 rounded-lg text-sm font-medium hover:bg-gray-200 transition-colors">
                    <i data-lucide="plus" class="w-4 h-4 mr-2"></i>Add Category
                </button>
            </div>
        </header>

        <main class="p-4 lg:p-6 space-y-6">
            <% if (error) { %>
            <div class="p-4 bg-red-500/10 border border-red-500/30 rounded-lg flex items-center">
                <i data-lucide="alert-circle" class="w-5 h-5 text-red-400 mr-3"></i>
                <span class="text-red-400"><%= error %></span>
            </div>
            <% } %>
            <% if (success) { %>
            <div class="p-4 bg-green-500/10 border border-green-500/30 rounded-lg flex items-center">
                <i data-lucide="check-circle" class="w-5 h-5 text-green-400 mr-3"></i>
                <span class="text-green-400"><%= success %></span>
            </div>
            <% } %>

            <% if (categories && categories.length > 0) { %>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
                <% categories.forEach(category => { %>
                <div class="card p-4">
                    <div class="flex items-start justify-between mb-3">
                        <div class="flex items-center space-x-3">
                            <div class="w-10 h-10 bg-dark-600 rounded-lg flex items-center justify-center text-lg">
                                <%= category.label ? category.label.split(' ')[0] : '💎' %>
                            </div>
                            <div>
                                <h3 class="font-medium text-white"><%= category.name %></h3>
                                <% if (category.urdu) { %>
                                <p class="text-xs text-dark-200"><%= category.urdu %></p>
                                <% } %>
                            </div>
                        </div>
                        <span class="px-2 py-1 text-xs rounded <%= category.isActive ? 'bg-green-500/20 text-green-400' : 'bg-dark-500 text-dark-200' %>">
                            <%= category.isActive ? 'Active' : 'Inactive' %>
                        </span>
                    </div>
                    
                    <% if (category.description) { %>
                    <p class="text-sm text-dark-100 mb-3 line-clamp-2"><%= category.description %></p>
                    <% } %>
                    
                    <div class="flex items-center justify-between text-xs text-dark-200 mb-4">
                        <span>Order: <%= category.order || 0 %></span>
                        <span><%= new Date(category.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %></span>
                    </div>
                    
                    <div class="flex items-center gap-2">
                        <button onclick="toggleCategoryStatus('<%= category._id %>')" class="flex-1 px-3 py-2 <%= category.isActive ? 'bg-orange-500/20 text-orange-400' : 'bg-green-500/20 text-green-400' %> rounded-lg text-sm transition-colors">
                            <i data-lucide="<%= category.isActive ? 'eye-off' : 'eye' %>" class="w-4 h-4 inline mr-1"></i>
                            <%= category.isActive ? 'Deactivate' : 'Activate' %>
                        </button>
                        <button onclick="deleteCategory('<%= category._id %>', '<%= category.name %>')" class="px-3 py-2 bg-red-500/20 text-red-400 hover:bg-red-500/30 rounded-lg text-sm transition-colors">
                            <i data-lucide="trash-2" class="w-4 h-4"></i>
                        </button>
                    </div>
                </div>
                <% }); %>
            </div>
            <% } else { %>
            <div class="card p-12 text-center">
                <div class="w-16 h-16 bg-dark-600 rounded-full flex items-center justify-center mx-auto mb-4">
                    <i data-lucide="tags" class="w-8 h-8 text-dark-300"></i>
                </div>
                <h3 class="text-lg font-semibold mb-2">No categories yet</h3>
                <p class="text-dark-200 mb-6">Add your first gemstone category to get started.</p>
                <button id="addFirstCategoryBtn" class="inline-flex items-center px-6 py-3 bg-white text-dark-900 rounded-lg font-medium hover:bg-gray-200 transition-colors">
                    <i data-lucide="plus" class="w-5 h-5 mr-2"></i>Add Category
                </button>
            </div>
            <% } %>
        </main>
    </div>

    <!-- Add Category Modal -->
    <div id="addCategoryModal" class="fixed inset-0 bg-black/70 z-50 hidden flex items-center justify-center p-4">
        <div class="bg-dark-800 border border-dark-600 rounded-xl max-w-md w-full">
            <div class="p-5 border-b border-dark-600">
                <h3 class="text-lg font-semibold flex items-center">
                    <i data-lucide="plus" class="w-5 h-5 mr-2"></i>Add New Category
                </h3>
            </div>
            
            <form action="/admin/categories/add" method="POST" class="p-5 space-y-4">
                <div>
                    <label for="name" class="block text-sm font-medium text-dark-100 mb-2">Name *</label>
                    <input type="text" id="name" name="name" required class="input-field w-full px-3 py-2.5 rounded-lg text-sm" placeholder="e.g., Amethyst">
                </div>
                <div>
                    <label for="urdu" class="block text-sm font-medium text-dark-100 mb-2">Urdu Name</label>
                    <input type="text" id="urdu" name="urdu" class="input-field w-full px-3 py-2.5 rounded-lg text-sm" placeholder="e.g., جمشت">
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label for="emoji" class="block text-sm font-medium text-dark-100 mb-2">Emoji</label>
                        <input type="text" id="emoji" name="emoji" maxlength="2" class="input-field w-full px-3 py-2.5 rounded-lg text-sm" placeholder="💜">
                    </div>
                    <div>
                        <label for="order" class="block text-sm font-medium text-dark-100 mb-2">Order</label>
                        <input type="number" id="order" name="order" min="0" class="input-field w-full px-3 py-2.5 rounded-lg text-sm" placeholder="0">
                    </div>
                </div>
                <div>
                    <label for="description" class="block text-sm font-medium text-dark-100 mb-2">Description</label>
                    <textarea id="description" name="description" rows="3" class="input-field w-full px-3 py-2.5 rounded-lg text-sm" placeholder="Brief description..."></textarea>
                </div>
                
                <div class="flex items-center gap-3 pt-2">
                    <button type="button" onclick="closeModal()" class="flex-1 px-4 py-2.5 bg-dark-600 hover:bg-dark-500 rounded-lg text-sm transition-colors">Cancel</button>
                    <button type="submit" class="flex-1 px-4 py-2.5 bg-white text-dark-900 hover:bg-gray-200 rounded-lg text-sm font-medium transition-colors">Add Category</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        lucide.createIcons();
        
        function toggleSidebar() {
            document.getElementById('sidebar').classList.toggle('-translate-x-full');
            document.getElementById('overlay').classList.toggle('hidden');
        }

        function openModal() { document.getElementById('addCategoryModal').classList.remove('hidden'); }
        function closeModal() { 
            document.getElementById('addCategoryModal').classList.add('hidden');
            document.querySelector('#addCategoryModal form').reset();
        }

        document.getElementById('addCategoryBtn')?.addEventListener('click', openModal);
        document.getElementById('addFirstCategoryBtn')?.addEventListener('click', openModal);
        document.getElementById('addCategoryModal').addEventListener('click', function(e) { if (e.target === this) closeModal(); });

        async function deleteCategory(id, name) {
            if (!confirm('Delete category "' + name + '"? This cannot be undone.')) return;
            try {
                const res = await fetch('/admin/categories/delete/' + id, { method: 'DELETE', headers: { 'Content-Type': 'application/json' }});
                const result = await res.json();
                if (result.success) window.location.href = '/admin/categories?success=' + encodeURIComponent(result.message);
                else alert('Error: ' + result.error);
            } catch (e) { alert('Failed to delete category.'); }
        }

        async function toggleCategoryStatus(id) {
            try {
                const res = await fetch('/admin/categories/toggle/' + id, { method: 'PUT', headers: { 'Content-Type': 'application/json' }});
                const result = await res.json();
                if (result.success) window.location.href = '/admin/categories?success=' + encodeURIComponent(result.message);
                else alert('Error: ' + result.error);
            } catch (e) { alert('Failed to update status.'); }
        }
    </script>
</body>
</html> 