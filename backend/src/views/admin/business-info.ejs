<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
    <style>
        * { font-family: 'Segoe UI', system-ui, sans-serif; }
        body { background: linear-gradient(135deg, #0f2027, #203a43, #2c5364); }
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: #0f2027; }
        ::-webkit-scrollbar-thumb { background: #d4af37; border-radius: 3px; }
        .sidebar { background: linear-gradient(180deg, #0f2027, #0a1a1f); }
        .nav-link { transition: all 0.2s ease; border-left: 3px solid transparent; }
        .nav-link:hover, .nav-link.active { background: rgba(212, 175, 55, 0.1); border-left-color: #d4af37; }
        .card { background: rgba(15, 32, 39, 0.8); border: 1px solid rgba(212, 175, 55, 0.15); border-radius: 12px; }
        .text-gold { color: #d4af37; }
        .border-gold { border-color: rgba(212, 175, 55, 0.3); }
        .btn-gold { background: linear-gradient(135deg, #d4af37, #c9a227); color: #0f2027; }
        .btn-gold:hover { transform: translateY(-2px); box-shadow: 0 10px 25px rgba(212, 175, 55, 0.3); }
        
        /* Input with shimmer glow on hover/focus */
        .input-glow {
            background: rgba(32, 58, 67, 0.6);
            border: 1px solid rgba(212, 175, 55, 0.2);
            color: #fff;
            transition: all 0.3s ease;
        }
        .input-glow:hover {
            border-color: rgba(212, 175, 55, 0.5);
            box-shadow: 0 0 15px rgba(212, 175, 55, 0.2);
        }
        .input-glow:focus {
            outline: none;
            border-color: #d4af37;
            box-shadow: 0 0 20px rgba(212, 175, 55, 0.4), 0 0 40px rgba(212, 175, 55, 0.1);
            background: rgba(32, 58, 67, 0.8);
        }
        .input-glow::placeholder { color: rgba(255,255,255,0.4); }
        
        .section-title { 
            color: #d4af37; 
            font-size: 14px; 
            font-weight: 600; 
            text-transform: uppercase; 
            letter-spacing: 0.1em; 
            display: flex; 
            align-items: center; 
            gap: 10px;
            margin-bottom: 20px;
            padding-bottom: 10px;
            border-bottom: 1px solid rgba(212, 175, 55, 0.2);
        }
    </style>
</head>
<body class="text-white min-h-screen">
    <% const activePage = 'business'; %>
    <%- include('partials/sidebar') %>

    <div class="lg:ml-64 min-h-screen">
        <header class="sticky top-0 z-30 h-16 bg-[#0f2027]/95 backdrop-blur border-b border-gold px-4">
            <div class="h-full flex items-center justify-between">
                <div class="flex items-center space-x-4">
                    <button onclick="toggleSidebar()" class="lg:hidden p-2 hover:bg-white/10 rounded">
                        <i data-lucide="menu" class="w-5 h-5"></i>
                    </button>
                    <h1 class="text-lg font-semibold">Shop Settings</h1>
                </div>
                <button type="submit" form="businessForm" class="btn-gold flex items-center px-4 py-2 rounded-lg text-sm font-medium transition-all">
                    <i data-lucide="save" class="w-4 h-4 mr-2"></i>Save
                </button>
            </div>
        </header>

        <main class="p-4 lg:p-6">
            <% if (typeof error !== 'undefined' && error) { %>
            <div class="mb-6 p-4 bg-red-500/10 border border-red-500/30 rounded-lg flex items-center">
                <i data-lucide="alert-circle" class="w-5 h-5 text-red-400 mr-3"></i><span class="text-red-400"><%= error %></span>
            </div>
            <% } %>
            <% if (typeof success !== 'undefined' && success) { %>
            <div class="mb-6 p-4 bg-green-500/10 border border-green-500/30 rounded-lg flex items-center">
                <i data-lucide="check-circle" class="w-5 h-5 text-green-400 mr-3"></i><span class="text-green-400"><%= success %></span>
            </div>
            <% } %>

            <form method="POST" action="/admin/business" id="businessForm" enctype="multipart/form-data" class="max-w-4xl space-y-6">
                
                <!-- Basic Info -->
                <div class="card p-6">
                    <div class="section-title"><i data-lucide="store" class="w-4 h-4"></i>Shop Details</div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm text-gray-300 mb-2">Shop Name</label>
                            <input type="text" name="shopName" value="<%= businessInfo?.shopName || '' %>" class="input-glow w-full px-4 py-3 rounded-lg text-sm" placeholder="Kohinoor Gemstone">
                        </div>
                        <div>
                            <label class="block text-sm text-gray-300 mb-2">Tagline</label>
                            <input type="text" name="tagline" value="<%= businessInfo?.tagline || '' %>" class="input-glow w-full px-4 py-3 rounded-lg text-sm" placeholder="Premium Authentic Gemstones">
                        </div>
                    </div>
                    <div class="mt-4">
                        <label class="block text-sm text-gray-300 mb-2">About Your Shop</label>
                        <textarea name="description" rows="3" class="input-glow w-full px-4 py-3 rounded-lg text-sm" placeholder="Tell customers about your shop..." maxlength="500"><%= businessInfo?.description || '' %></textarea>
                    </div>
                </div>

                <!-- Contact Info -->
                <div class="card p-6">
                    <div class="section-title"><i data-lucide="phone" class="w-4 h-4"></i>Contact Details</div>
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                        <div>
                            <label class="block text-sm text-gray-300 mb-2">Phone Number</label>
                            <input type="tel" name="contact[phone]" value="<%= businessInfo?.contact?.phone || '' %>" class="input-glow w-full px-4 py-3 rounded-lg text-sm" placeholder="+91 98765 43210">
                        </div>
                        <div>
                            <label class="block text-sm text-gray-300 mb-2">WhatsApp</label>
                            <input type="tel" name="contact[whatsapp]" value="<%= businessInfo?.contact?.whatsapp || '' %>" class="input-glow w-full px-4 py-3 rounded-lg text-sm" placeholder="+91 98765 43210">
                        </div>
                        <div>
                            <label class="block text-sm text-gray-300 mb-2">Email</label>
                            <input type="email" name="contact[email]" value="<%= businessInfo?.contact?.email || '' %>" class="input-glow w-full px-4 py-3 rounded-lg text-sm" placeholder="info@kohinoor.com">
                        </div>
                    </div>
                </div>

                <!-- Address -->
                <div class="card p-6">
                    <div class="section-title"><i data-lucide="map-pin" class="w-4 h-4"></i>Shop Address</div>
                    <div class="space-y-4">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div>
                                <label class="block text-sm text-gray-300 mb-2">Street Address</label>
                                <input type="text" name="address[street]" value="<%= businessInfo?.address?.street || '' %>" class="input-glow w-full px-4 py-3 rounded-lg text-sm" placeholder="Shop No. 123, Main Market">
                            </div>
                            <div>
                                <label class="block text-sm text-gray-300 mb-2">Area</label>
                                <input type="text" name="address[area]" value="<%= businessInfo?.address?.area || '' %>" class="input-glow w-full px-4 py-3 rounded-lg text-sm" placeholder="Jewelry Market">
                            </div>
                        </div>
                        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                            <div>
                                <label class="block text-sm text-gray-300 mb-2">City</label>
                                <input type="text" name="address[city]" value="<%= businessInfo?.address?.city || '' %>" class="input-glow w-full px-4 py-3 rounded-lg text-sm" placeholder="Bareilly">
                            </div>
                            <div>
                                <label class="block text-sm text-gray-300 mb-2">State</label>
                                <input type="text" name="address[state]" value="<%= businessInfo?.address?.state || '' %>" class="input-glow w-full px-4 py-3 rounded-lg text-sm" placeholder="UP">
                            </div>
                            <div>
                                <label class="block text-sm text-gray-300 mb-2">Pincode</label>
                                <input type="text" name="address[pincode]" value="<%= businessInfo?.address?.pincode || '' %>" class="input-glow w-full px-4 py-3 rounded-lg text-sm" placeholder="243001">
                            </div>
                            <div>
                                <label class="block text-sm text-gray-300 mb-2">Country</label>
                                <input type="text" name="address[country]" value="<%= businessInfo?.address?.country || 'India' %>" class="input-glow w-full px-4 py-3 rounded-lg text-sm" placeholder="India">
                            </div>
                        </div>
                        <div>
                            <label class="block text-sm text-gray-300 mb-2">Google Maps Link</label>
                            <input type="url" name="googleMapsUrl" value="<%= businessInfo?.googleMapsUrl || '' %>" class="input-glow w-full px-4 py-3 rounded-lg text-sm" placeholder="https://maps.google.com/...">
                        </div>
                    </div>
                </div>

                <!-- Business Hours -->
                <div class="card p-6">
                    <div class="section-title"><i data-lucide="clock" class="w-4 h-4"></i>Shop Timings</div>
                    <div class="space-y-3">
                        <% const days = ['monday', 'tuesday', 'wednesday', 'thursday', 'friday', 'saturday', 'sunday']; %>
                        <% days.forEach(day => { %>
                        <div class="flex items-center gap-4 p-3 bg-white/5 rounded-lg hover:bg-gold/5 transition-colors">
                            <div class="w-24 text-sm font-medium capitalize text-gold"><%= day %></div>
                            <div class="flex items-center gap-2 flex-1">
                                <input type="time" name="businessHours[<%= day %>][open]" value="<%= businessInfo?.businessHours?.[day]?.open || '10:00' %>" class="input-glow px-3 py-2 rounded-lg text-sm">
                                <span class="text-gray-400">to</span>
                                <input type="time" name="businessHours[<%= day %>][close]" value="<%= businessInfo?.businessHours?.[day]?.close || '20:00' %>" class="input-glow px-3 py-2 rounded-lg text-sm">
                            </div>
                            <label class="flex items-center gap-2 cursor-pointer">
                                <input type="checkbox" name="businessHours[<%= day %>][closed]" <%= businessInfo?.businessHours?.[day]?.closed ? 'checked' : '' %> class="w-4 h-4 rounded accent-yellow-500">
                                <span class="text-sm text-gray-400">Closed</span>
                            </label>
                        </div>
                        <% }); %>
                    </div>
                </div>

                <!-- Social Media (without Twitter) -->
                <div class="card p-6">
                    <div class="section-title"><i data-lucide="share-2" class="w-4 h-4"></i>Social Media</div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm text-gray-300 mb-2">Instagram</label>
                            <input type="url" name="socialMedia[instagram]" value="<%= businessInfo?.socialMedia?.instagram || '' %>" class="input-glow w-full px-4 py-3 rounded-lg text-sm" placeholder="https://instagram.com/...">
                        </div>
                        <div>
                            <label class="block text-sm text-gray-300 mb-2">Facebook</label>
                            <input type="url" name="socialMedia[facebook]" value="<%= businessInfo?.socialMedia?.facebook || '' %>" class="input-glow w-full px-4 py-3 rounded-lg text-sm" placeholder="https://facebook.com/...">
                        </div>
                        <div>
                            <label class="block text-sm text-gray-300 mb-2">YouTube</label>
                            <input type="url" name="socialMedia[youtube]" value="<%= businessInfo?.socialMedia?.youtube || '' %>" class="input-glow w-full px-4 py-3 rounded-lg text-sm" placeholder="https://youtube.com/...">
                        </div>
                        <div>
                            <label class="block text-sm text-gray-300 mb-2">LinkedIn</label>
                            <input type="url" name="socialMedia[linkedin]" value="<%= businessInfo?.socialMedia?.linkedin || '' %>" class="input-glow w-full px-4 py-3 rounded-lg text-sm" placeholder="https://linkedin.com/...">
                        </div>
                    </div>
                </div>

                <!-- Store Certification (JG Gems Testing Lab) -->
                <div class="card p-6">
                    <div class="section-title"><i data-lucide="badge-check" class="w-4 h-4"></i>Store Certification</div>
                    <p class="text-xs text-gray-400 mb-4">Display your testing lab certification to build trust with customers</p>
                    
                    <!-- Enable/Disable Toggle -->
                    <div class="flex items-center gap-3 mb-6 p-3 bg-gold/10 rounded-lg">
                        <input type="checkbox" name="storeCertification[enabled]" id="certEnabled" <%= businessInfo?.storeCertification?.enabled ? 'checked' : '' %> class="w-5 h-5 rounded accent-yellow-500">
                        <label for="certEnabled" class="text-sm font-medium cursor-pointer">Enable Store Certification Badge</label>
                    </div>
                    
                    <div class="space-y-4">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div>
                                <label class="block text-sm text-gray-300 mb-2">Lab Name</label>
                                <input type="text" name="storeCertification[labName]" value="<%= businessInfo?.storeCertification?.labName || 'JG Gems Testing Lab' %>" class="input-glow w-full px-4 py-3 rounded-lg text-sm" placeholder="JG Gems Testing Lab">
                            </div>
                            <div>
                                <label class="block text-sm text-gray-300 mb-2">Lab Website</label>
                                <input type="url" name="storeCertification[labWebsite]" value="<%= businessInfo?.storeCertification?.labWebsite || '' %>" class="input-glow w-full px-4 py-3 rounded-lg text-sm" placeholder="https://www.jggtljaipur.com">
                            </div>
                        </div>
                        <div>
                            <label class="block text-sm text-gray-300 mb-2">Lab Address</label>
                            <input type="text" name="storeCertification[labAddress]" value="<%= businessInfo?.storeCertification?.labAddress || '' %>" class="input-glow w-full px-4 py-3 rounded-lg text-sm" placeholder="2406, Dai Ki Gali, Ghee Walon Ka Rasta, Johari Bazar, Jaipur">
                        </div>
                        <div>
                            <label class="block text-sm text-gray-300 mb-2">Tagline</label>
                            <input type="text" name="storeCertification[tagline]" value="<%= businessInfo?.storeCertification?.tagline || '' %>" class="input-glow w-full px-4 py-3 rounded-lg text-sm" placeholder="India's Most Authentic & Promising Testing Authority">
                        </div>
                        <div>
                            <label class="block text-sm text-gray-300 mb-2">Description (shown in About Us)</label>
                            <textarea name="storeCertification[description]" rows="3" class="input-glow w-full px-4 py-3 rounded-lg text-sm" placeholder="All our gemstones are tested and certified by JG Gems Testing Lab..." maxlength="500"><%= businessInfo?.storeCertification?.description || '' %></textarea>
                        </div>
                        <div>
                            <label class="block text-sm text-gray-300 mb-2">Certification Image/Certificate</label>
                            <div class="flex items-start gap-4">
                                <% if (businessInfo?.storeCertification?.certificationImage) { %>
                                <div class="relative group">
                                    <img src="<%= businessInfo.storeCertification.certificationImage %>" alt="Certification" class="w-40 h-28 object-cover rounded-lg border border-gold/30">
                                    <div class="absolute inset-0 bg-black/50 opacity-0 group-hover:opacity-100 transition-opacity rounded-lg flex items-center justify-center">
                                        <span class="text-white text-xs">Current Certificate</span>
                                    </div>
                                </div>
                                <% } %>
                                <div class="flex-1">
                                    <div class="upload-zone rounded-xl p-6 text-center cursor-pointer border-2 border-dashed border-gold/30 hover:border-gold/60 transition-colors" onclick="document.getElementById('certImage').click()">
                                        <input type="file" id="certImage" name="certificationImage" accept="image/*" class="hidden" onchange="previewCertImage(this)">
                                        <i data-lucide="upload-cloud" class="w-8 h-8 text-gold mx-auto mb-2"></i>
                                        <p class="text-gray-300 text-sm mb-1">Click to upload certificate</p>
                                        <p class="text-xs text-gray-500">PNG, JPG up to 10MB</p>
                                    </div>
                                    <div id="certImagePreview" class="mt-3 hidden">
                                        <img id="certPreviewImg" src="" alt="Preview" class="w-full max-w-xs h-auto rounded-lg border border-gold/30">
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Heritage -->
                <div class="card p-6">
                    <div class="section-title"><i data-lucide="award" class="w-4 h-4"></i>About Us</div>
                    <div class="space-y-4">
                        <div>
                            <label class="block text-sm text-gray-300 mb-2">Started In (Year)</label>
                            <input type="number" name="heritage[foundedYear]" value="<%= businessInfo?.heritage?.foundedYear || '' %>" class="input-glow w-full md:w-32 px-4 py-3 rounded-lg text-sm" placeholder="1990">
                        </div>
                        <div>
                            <label class="block text-sm text-gray-300 mb-2">Our Story</label>
                            <textarea name="heritage[story]" rows="4" class="input-glow w-full px-4 py-3 rounded-lg text-sm" placeholder="Share your journey..." maxlength="1000"><%= businessInfo?.heritage?.story || '' %></textarea>
                        </div>
                        <div>
                            <label class="block text-sm text-gray-300 mb-2">Our Specialties (comma separated)</label>
                            <input type="text" name="heritage[specialties]" value="<%= businessInfo?.heritage?.specialties?.join(', ') || '' %>" class="input-glow w-full px-4 py-3 rounded-lg text-sm" placeholder="Ruby, Emerald, Sapphire">
                        </div>
                    </div>
                </div>

                <!-- Policies -->
                <div class="card p-6">
                    <div class="section-title"><i data-lucide="file-text" class="w-4 h-4"></i>Policies</div>
                    <div class="space-y-4">
                        <div>
                            <label class="block text-sm text-gray-300 mb-2">Return Policy</label>
                            <textarea name="policies[returnPolicy]" rows="3" class="input-glow w-full px-4 py-3 rounded-lg text-sm" placeholder="How customers can return items..."><%= businessInfo?.policies?.returnPolicy || '' %></textarea>
                        </div>
                        <div>
                            <label class="block text-sm text-gray-300 mb-2">Shipping Policy</label>
                            <textarea name="policies[shippingPolicy]" rows="3" class="input-glow w-full px-4 py-3 rounded-lg text-sm" placeholder="How you ship orders..."><%= businessInfo?.policies?.shippingPolicy || '' %></textarea>
                        </div>
                    </div>
                </div>

                <!-- SEO Settings (helpful for Google) -->
                <div class="card p-6">
                    <div class="section-title"><i data-lucide="search" class="w-4 h-4"></i>Google Settings (SEO)</div>
                    <p class="text-xs text-gray-400 mb-4">These help your shop appear in Google search results</p>
                    <div class="space-y-4">
                        <div>
                            <label class="block text-sm text-gray-300 mb-2">Page Title (shows in Google)</label>
                            <input type="text" name="seoSettings[metaTitle]" value="<%= businessInfo?.seoSettings?.metaTitle || '' %>" class="input-glow w-full px-4 py-3 rounded-lg text-sm" placeholder="Kohinoor Gemstone - Best Gemstones in Bareilly" maxlength="60">
                        </div>
                        <div>
                            <label class="block text-sm text-gray-300 mb-2">Description (shows in Google)</label>
                            <textarea name="seoSettings[metaDescription]" rows="2" class="input-glow w-full px-4 py-3 rounded-lg text-sm" placeholder="Buy authentic gemstones..." maxlength="160"><%= businessInfo?.seoSettings?.metaDescription || '' %></textarea>
                        </div>
                        <div>
                            <label class="block text-sm text-gray-300 mb-2">Keywords (comma separated)</label>
                            <input type="text" name="seoSettings[keywords]" value="<%= businessInfo?.seoSettings?.keywords?.join(', ') || '' %>" class="input-glow w-full px-4 py-3 rounded-lg text-sm" placeholder="gemstones, ruby, emerald, sapphire">
                        </div>
                    </div>
                </div>

                <!-- Submit -->
                <div class="flex gap-3">
                    <a href="/admin/dashboard" class="flex-1 px-6 py-3 bg-white/10 hover:bg-white/20 rounded-lg text-center text-sm transition-colors">Cancel</a>
                    <button type="submit" class="btn-gold flex-1 px-6 py-3 rounded-lg font-medium text-sm transition-all flex items-center justify-center">
                        <i data-lucide="save" class="w-4 h-4 mr-2"></i>Save All
                    </button>
                </div>
            </form>
        </main>
    </div>

    <script>
        lucide.createIcons();
        function toggleSidebar() {
            document.getElementById('sidebar').classList.toggle('-translate-x-full');
            document.getElementById('overlay').classList.toggle('hidden');
        }
        
        function previewCertImage(input) {
            const preview = document.getElementById('certImagePreview');
            const previewImg = document.getElementById('certPreviewImg');
            
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    previewImg.src = e.target.result;
                    preview.classList.remove('hidden');
                };
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
</body>
</html>
