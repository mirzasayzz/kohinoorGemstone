<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
    <style>
        * { font-family: 'Segoe UI', system-ui, sans-serif; }
        body { background: linear-gradient(135deg, #0f2027, #203a43, #2c5364); }
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: #0f2027; }
        ::-webkit-scrollbar-thumb { background: #d4af37; border-radius: 3px; }
        .sidebar { background: linear-gradient(180deg, #0f2027, #0a1a1f); }
        .nav-link { transition: all 0.2s ease; border-left: 3px solid transparent; }
        .nav-link:hover, .nav-link.active { background: rgba(212, 175, 55, 0.1); border-left-color: #d4af37; }
        .card { background: rgba(15, 32, 39, 0.8); border: 1px solid rgba(212, 175, 55, 0.15); border-radius: 12px; }
        .text-gold { color: #d4af37; }
        .border-gold { border-color: rgba(212, 175, 55, 0.3); }
        .btn-gold { background: linear-gradient(135deg, #d4af37, #c9a227); color: #0f2027; }
        .input-glow { background: rgba(32, 58, 67, 0.6); border: 1px solid rgba(212, 175, 55, 0.2); color: #fff; }
        .input-glow:focus { outline: none; border-color: #d4af37; box-shadow: 0 0 20px rgba(212, 175, 55, 0.4); }
    </style>
</head>
<body class="text-white min-h-screen">
    <% const activePage = 'users'; %>
    <%- include('partials/sidebar') %>

    <div class="lg:ml-64 min-h-screen">
        <header class="sticky top-0 z-30 h-16 bg-[#0f2027]/95 backdrop-blur border-b border-gold px-4">
            <div class="h-full flex items-center justify-between">
                <div class="flex items-center space-x-2 sm:space-x-4 min-w-0">
                    <button onclick="toggleSidebar()" class="lg:hidden p-2 hover:bg-white/10 rounded flex-shrink-0">
                        <i data-lucide="menu" class="w-5 h-5"></i>
                    </button>
                    <h1 class="text-base sm:text-lg font-semibold truncate">Users</h1>
                    <span class="px-2 py-1 bg-gold/20 rounded text-xs text-gold flex-shrink-0"><%= users.length %></span>
                </div>
            </div>
        </header>

        <main class="p-4 lg:p-6 space-y-6">
            <!-- Stats Cards -->
            <div class="grid grid-cols-2 gap-3 sm:gap-4">
                <div class="card p-3 sm:p-5">
                    <div class="flex items-center justify-between mb-2">
                        <span class="text-xs text-gray-400">Total</span>
                        <div class="w-8 h-8 sm:w-10 sm:h-10 bg-gold/20 rounded-lg flex items-center justify-center">
                            <i data-lucide="users" class="w-4 h-4 sm:w-5 sm:h-5 text-gold"></i>
                        </div>
                    </div>
                    <p class="text-xl sm:text-2xl font-bold"><%= users.length %></p>
                </div>
                <div class="card p-3 sm:p-5">
                    <div class="flex items-center justify-between mb-2">
                        <span class="text-xs text-gray-400">Verified</span>
                        <div class="w-8 h-8 sm:w-10 sm:h-10 bg-green-500/20 rounded-lg flex items-center justify-center">
                            <i data-lucide="check-circle" class="w-4 h-4 sm:w-5 sm:h-5 text-green-400"></i>
                        </div>
                    </div>
                    <p class="text-xl sm:text-2xl font-bold"><%= users.filter(u => u.isEmailVerified).length %></p>
                </div>
                <div class="card p-3 sm:p-5">
                    <div class="flex items-center justify-between mb-2">
                        <span class="text-xs text-gray-400">Active</span>
                        <div class="w-8 h-8 sm:w-10 sm:h-10 bg-blue-500/20 rounded-lg flex items-center justify-center">
                            <i data-lucide="activity" class="w-4 h-4 sm:w-5 sm:h-5 text-blue-400"></i>
                        </div>
                    </div>
                    <p class="text-xl sm:text-2xl font-bold"><%= users.filter(u => u.lastLogin && new Date(u.lastLogin).toDateString() === new Date().toDateString()).length %></p>
                </div>
                <div class="card p-3 sm:p-5">
                    <div class="flex items-center justify-between mb-2">
                        <span class="text-xs text-gray-400">New</span>
                        <div class="w-8 h-8 sm:w-10 sm:h-10 bg-purple-500/20 rounded-lg flex items-center justify-center">
                            <i data-lucide="user-plus" class="w-4 h-4 sm:w-5 sm:h-5 text-purple-400"></i>
                        </div>
                    </div>
                    <% const weekAgo = new Date(Date.now() - 7*24*60*60*1000); %>
                    <p class="text-xl sm:text-2xl font-bold"><%= users.filter(u => new Date(u.createdAt) > weekAgo).length %></p>
                </div>
            </div>

            <!-- Search -->
            <div class="card p-4">
                <div class="relative">
                    <i data-lucide="search" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gold"></i>
                    <input type="text" id="searchInput" placeholder="Search users..." class="input-glow w-full pl-10 pr-4 py-3 rounded-lg text-sm" oninput="filterUsers()">
                </div>
            </div>

            <!-- Users Table -->
            <div class="card overflow-hidden">
                <div class="overflow-x-auto">
                    <table class="w-full">
                        <thead class="bg-gold/10">
                            <tr class="text-left text-xs text-gold uppercase tracking-wider">
                                <th class="px-4 py-3">User</th>
                                <th class="px-4 py-3 hidden md:table-cell">Contact</th>
                                <th class="px-4 py-3 hidden lg:table-cell">Address</th>
                                <th class="px-4 py-3 hidden sm:table-cell">Joined</th>
                                <th class="px-4 py-3">Status</th>
                                <th class="px-4 py-3">Actions</th>
                            </tr>
                        </thead>
                        <tbody id="usersTable" class="divide-y divide-gold/10">
                            <% users.forEach(customer => { %>
                            <tr class="user-row hover:bg-gold/5 transition-colors" data-name="<%= customer.name.toLowerCase() %>" data-email="<%= customer.email.toLowerCase() %>" data-phone="<%= customer.phone || '' %>">
                                <td class="px-4 py-3">
                                    <div class="flex items-center">
                                        <div class="w-10 h-10 bg-gold/20 rounded-full flex items-center justify-center mr-3">
                                            <% if (customer.avatar) { %>
                                            <img src="<%= customer.avatar %>" class="w-10 h-10 rounded-full object-cover">
                                            <% } else { %>
                                            <span class="text-gold font-bold"><%= customer.name.charAt(0).toUpperCase() %></span>
                                            <% } %>
                                        </div>
                                        <div>
                                            <p class="font-medium text-white"><%= customer.name %></p>
                                            <p class="text-xs text-gray-400"><%= customer.email %></p>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-4 py-3 hidden md:table-cell">
                                    <p class="text-xs text-gold"><%= customer.phone || 'No phone' %></p>
                                    <% if (customer.dateOfBirth) { %>
                                    <p class="text-xs text-gray-400">DOB: <%= new Date(customer.dateOfBirth).toLocaleDateString('en-IN') %></p>
                                    <% } %>
                                </td>
                                <td class="px-4 py-3 hidden lg:table-cell">
                                    <% if (customer.address && customer.address.city) { %>
                                    <p class="text-sm text-gray-300"><%= customer.address.city %>, <%= customer.address.state || '' %></p>
                                    <p class="text-xs text-gray-500"><%= customer.address.pincode || '' %></p>
                                    <% } else { %>
                                    <span class="text-xs text-gray-500">Not provided</span>
                                    <% } %>
                                </td>
                                <td class="px-4 py-3 hidden sm:table-cell">
                                    <p class="text-sm text-gray-300"><%= new Date(customer.createdAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %></p>
                                    <% if (customer.lastLogin) { %>
                                    <p class="text-xs text-gray-500">Last: <%= new Date(customer.lastLogin).toLocaleDateString() %></p>
                                    <% } %>
                                </td>
                                <td class="px-4 py-3">
                                    <% if (customer.isEmailVerified) { %>
                                    <span class="px-2 py-1 bg-green-500/20 text-green-400 text-xs rounded-full">Verified</span>
                                    <% } else { %>
                                    <span class="px-2 py-1 bg-yellow-500/20 text-yellow-400 text-xs rounded-full">Pending</span>
                                    <% } %>
                                </td>
                                <td class="px-2 sm:px-4 py-3">
                                    <div class="flex items-center space-x-1">
                                        <a href="/admin/chats/<%= customer._id %>" class="p-1.5 sm:p-2 hover:bg-gold/20 rounded-lg text-gold transition-colors" title="Chat">
                                            <i data-lucide="message-circle" class="w-3 h-3 sm:w-4 sm:h-4"></i>
                                        </a>
                                        <button onclick="deleteUser('<%= customer._id %>', '<%= customer.name %>')" class="p-1.5 sm:p-2 hover:bg-red-500/20 rounded-lg text-red-400 transition-colors" title="Delete">
                                            <i data-lucide="trash-2" class="w-3 h-3 sm:w-4 sm:h-4"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
                
                <% if (users.length === 0) { %>
                <div class="text-center py-12">
                    <i data-lucide="users" class="w-16 h-16 text-gold/30 mx-auto mb-4"></i>
                    <p class="text-gray-400">No users registered yet</p>
                </div>
                <% } %>
            </div>
        </main>
    </div>

    <script>
        lucide.createIcons();
        
        function toggleSidebar() {
            document.getElementById('sidebar').classList.toggle('-translate-x-full');
            document.getElementById('overlay').classList.toggle('hidden');
        }

        function filterUsers() {
            const search = document.getElementById('searchInput').value.toLowerCase();
            const rows = document.querySelectorAll('.user-row');
            
            rows.forEach(row => {
                const name = row.dataset.name;
                const email = row.dataset.email;
                const phone = row.dataset.phone;
                const matches = name.includes(search) || email.includes(search) || phone.includes(search);
                row.style.display = matches ? '' : 'none';
            });
        }

        async function deleteUser(userId, userName) {
            if (!confirm(`Are you sure you want to delete "${userName}"?\n\nThis will permanently remove:\n- User account\n- All their messages\n- All their data\n\nThis action cannot be undone!`)) {
                return;
            }

            try {
                const response = await fetch(`/admin/users/${userId}`, {
                    method: 'DELETE',
                    headers: { 'Content-Type': 'application/json' }
                });

                const data = await response.json();

                if (data.success) {
                    alert(data.message);
                    window.location.reload();
                } else {
                    alert('Error: ' + data.message);
                }
            } catch (error) {
                console.error('Delete error:', error);
                alert('Failed to delete user. Please try again.');
            }
        }
    </script>
</body>
</html>
