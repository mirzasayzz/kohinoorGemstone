<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
    <style>
        * { font-family: 'Segoe UI', system-ui, sans-serif; }
        body { background: linear-gradient(135deg, #0f2027, #203a43, #2c5364); }
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: #0f2027; }
        ::-webkit-scrollbar-thumb { background: #d4af37; border-radius: 3px; }
        .sidebar { background: linear-gradient(180deg, #0f2027, #0a1a1f); }
        .nav-link { transition: all 0.2s ease; border-left: 3px solid transparent; }
        .nav-link:hover, .nav-link.active { background: rgba(212, 175, 55, 0.1); border-left-color: #d4af37; }
        .card { background: rgba(15, 32, 39, 0.8); border: 1px solid rgba(212, 175, 55, 0.15); border-radius: 12px; }
        .text-gold { color: #d4af37; }
        .border-gold { border-color: rgba(212, 175, 55, 0.3); }
        .btn-gold { background: linear-gradient(135deg, #d4af37, #c9a227); color: #0f2027; }
        .input-glow { background: rgba(32, 58, 67, 0.6); border: 1px solid rgba(212, 175, 55, 0.2); color: #fff; }
        .input-glow:focus { outline: none; border-color: #d4af37; box-shadow: 0 0 20px rgba(212, 175, 55, 0.4); }
    </style>
</head>
<body class="text-white min-h-screen">
    <% const activePage = 'admins'; %>
    <%- include('partials/sidebar') %>

    <div class="lg:ml-64 min-h-screen">
        <header class="sticky top-0 z-30 h-16 bg-[#0f2027]/95 backdrop-blur border-b border-gold px-4">
            <div class="h-full flex items-center justify-between">
                <div class="flex items-center space-x-4">
                    <button onclick="toggleSidebar()" class="lg:hidden p-2 hover:bg-white/10 rounded">
                        <i data-lucide="menu" class="w-5 h-5"></i>
                    </button>
                    <h1 class="text-lg font-semibold">Manage Admins</h1>
                    <span class="px-2 py-1 bg-purple-500/20 text-purple-400 rounded text-xs">Super Admin Only</span>
                </div>
                <button onclick="openAddModal()" class="btn-gold px-4 py-2 rounded-lg text-sm font-medium flex items-center">
                    <i data-lucide="plus" class="w-4 h-4 mr-2"></i>Add Admin
                </button>
            </div>
        </header>

        <main class="p-4 lg:p-6 space-y-6">
            <% if (typeof error !== 'undefined' && error) { %>
            <div class="p-4 bg-red-500/10 border border-red-500/30 rounded-lg flex items-center">
                <i data-lucide="alert-circle" class="w-5 h-5 text-red-400 mr-3"></i>
                <span class="text-red-400"><%= error %></span>
            </div>
            <% } %>
            
            <% if (typeof success !== 'undefined' && success) { %>
            <div class="p-4 bg-green-500/10 border border-green-500/30 rounded-lg flex items-center">
                <i data-lucide="check-circle" class="w-5 h-5 text-green-400 mr-3"></i>
                <span class="text-green-400"><%= success %></span>
            </div>
            <% } %>

            <!-- Admins Table -->
            <div class="card overflow-hidden">
                <div class="overflow-x-auto">
                    <table class="w-full">
                        <thead class="bg-gold/10">
                            <tr class="text-left text-xs text-gold uppercase tracking-wider">
                                <th class="px-4 py-3">Admin</th>
                                <th class="px-4 py-3">Email</th>
                                <th class="px-4 py-3">Role</th>
                                <th class="px-4 py-3">Status</th>
                                <th class="px-4 py-3">Last Login</th>
                                <th class="px-4 py-3">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gold/10">
                            <% admins.forEach(admin => { %>
                            <tr class="hover:bg-gold/5 transition-colors">
                                <td class="px-4 py-3">
                                    <div class="flex items-center">
                                        <div class="w-10 h-10 bg-gold/20 rounded-full flex items-center justify-center mr-3">
                                            <% if (admin.role === 'super_admin') { %>
                                            <i data-lucide="crown" class="w-5 h-5 text-gold"></i>
                                            <% } else { %>
                                            <i data-lucide="shield" class="w-5 h-5 text-blue-400"></i>
                                            <% } %>
                                        </div>
                                        <div>
                                            <p class="font-medium text-white"><%= admin.name %></p>
                                            <p class="text-xs text-gray-400">ID: <%= admin._id.toString().slice(-6) %></p>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-4 py-3 text-gray-300"><%= admin.email %></td>
                                <td class="px-4 py-3">
                                    <% if (admin.role === 'super_admin') { %>
                                    <span class="px-2 py-1 bg-gold/20 text-gold text-xs rounded-full">Super Admin</span>
                                    <% } else { %>
                                    <span class="px-2 py-1 bg-blue-500/20 text-blue-400 text-xs rounded-full">Admin</span>
                                    <% } %>
                                </td>
                                <td class="px-4 py-3">
                                    <% if (admin.isActive) { %>
                                    <span class="px-2 py-1 bg-green-500/20 text-green-400 text-xs rounded-full">Active</span>
                                    <% } else { %>
                                    <span class="px-2 py-1 bg-red-500/20 text-red-400 text-xs rounded-full">Inactive</span>
                                    <% } %>
                                </td>
                                <td class="px-4 py-3 text-sm text-gray-400">
                                    <% if (admin.lastLogin) { %>
                                    <%= new Date(admin.lastLogin).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' }) %>
                                    <% } else { %>
                                    Never
                                    <% } %>
                                </td>
                                <td class="px-4 py-3">
                                    <% if (admin._id.toString() !== user.id && admin.role !== 'super_admin') { %>
                                    <div class="flex items-center space-x-2">
                                        <button onclick="toggleStatus('<%= admin._id %>', <%= admin.isActive %>)" class="p-2 hover:bg-white/10 rounded-lg text-gray-400 hover:text-white transition-colors" title="<%= admin.isActive ? 'Deactivate' : 'Activate' %>">
                                            <i data-lucide="<%= admin.isActive ? 'user-x' : 'user-check' %>" class="w-4 h-4"></i>
                                        </button>
                                        <button onclick="confirmDelete('<%= admin._id %>', '<%= admin.name %>')" class="p-2 hover:bg-red-500/20 rounded-lg text-gray-400 hover:text-red-400 transition-colors" title="Delete">
                                            <i data-lucide="trash-2" class="w-4 h-4"></i>
                                        </button>
                                    </div>
                                    <% } else { %>
                                    <span class="text-xs text-gray-500">Protected</span>
                                    <% } %>
                                </td>
                            </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
                
                <% if (admins.length === 0) { %>
                <div class="text-center py-12">
                    <i data-lucide="shield" class="w-16 h-16 text-gold/30 mx-auto mb-4"></i>
                    <p class="text-gray-400">No admin users found</p>
                </div>
                <% } %>
            </div>
        </main>
    </div>

    <!-- Add Admin Modal -->
    <div id="addModal" class="fixed inset-0 bg-black/60 z-50 flex items-center justify-center hidden">
        <div class="card p-6 w-full max-w-md mx-4">
            <div class="flex items-center justify-between mb-6">
                <h2 class="text-lg font-semibold">Add New Admin</h2>
                <button onclick="closeAddModal()" class="p-2 hover:bg-white/10 rounded">
                    <i data-lucide="x" class="w-5 h-5"></i>
                </button>
            </div>
            
            <form method="POST" action="/admin/admins/add" class="space-y-4">
                <div>
                    <label class="block text-sm text-gray-300 mb-2">Name *</label>
                    <input type="text" name="name" required class="input-glow w-full px-4 py-3 rounded-lg text-sm" placeholder="Admin Name">
                </div>
                <div>
                    <label class="block text-sm text-gray-300 mb-2">Email *</label>
                    <input type="email" name="email" required class="input-glow w-full px-4 py-3 rounded-lg text-sm" placeholder="admin@example.com">
                </div>
                <div>
                    <label class="block text-sm text-gray-300 mb-2">Password *</label>
                    <input type="password" name="password" required minlength="6" class="input-glow w-full px-4 py-3 rounded-lg text-sm" placeholder="Min 6 characters">
                </div>
                <div>
                    <label class="block text-sm text-gray-300 mb-2">Role *</label>
                    <select name="role" required class="input-glow w-full px-4 py-3 rounded-lg text-sm">
                        <option value="admin">Admin</option>
                        <option value="super_admin">Super Admin</option>
                    </select>
                </div>
                <div class="flex gap-3 pt-4">
                    <button type="button" onclick="closeAddModal()" class="flex-1 px-4 py-3 bg-white/10 hover:bg-white/20 rounded-lg text-sm transition-colors">Cancel</button>
                    <button type="submit" class="btn-gold flex-1 px-4 py-3 rounded-lg text-sm font-medium">Create Admin</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Delete Confirmation Modal -->
    <div id="deleteModal" class="fixed inset-0 bg-black/60 z-50 flex items-center justify-center hidden">
        <div class="card p-6 w-full max-w-sm mx-4 text-center">
            <i data-lucide="alert-triangle" class="w-16 h-16 text-red-400 mx-auto mb-4"></i>
            <h2 class="text-lg font-semibold mb-2">Delete Admin?</h2>
            <p class="text-gray-400 text-sm mb-6">Are you sure you want to delete <span id="deleteName" class="text-white font-medium"></span>?</p>
            <form method="POST" id="deleteForm">
                <div class="flex gap-3">
                    <button type="button" onclick="closeDeleteModal()" class="flex-1 px-4 py-3 bg-white/10 hover:bg-white/20 rounded-lg text-sm transition-colors">Cancel</button>
                    <button type="submit" class="flex-1 px-4 py-3 bg-red-500 hover:bg-red-600 rounded-lg text-sm font-medium">Delete</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        lucide.createIcons();
        
        function toggleSidebar() {
            document.getElementById('sidebar').classList.toggle('-translate-x-full');
            document.getElementById('overlay').classList.toggle('hidden');
        }

        function openAddModal() {
            document.getElementById('addModal').classList.remove('hidden');
        }

        function closeAddModal() {
            document.getElementById('addModal').classList.add('hidden');
        }

        function confirmDelete(id, name) {
            document.getElementById('deleteName').textContent = name;
            document.getElementById('deleteForm').action = '/admin/admins/delete/' + id;
            document.getElementById('deleteModal').classList.remove('hidden');
        }

        function closeDeleteModal() {
            document.getElementById('deleteModal').classList.add('hidden');
        }

        function toggleStatus(id, currentStatus) {
            if (confirm(currentStatus ? 'Deactivate this admin?' : 'Activate this admin?')) {
                window.location.href = '/admin/admins/toggle/' + id;
            }
        }
    </script>
</body>
</html>
