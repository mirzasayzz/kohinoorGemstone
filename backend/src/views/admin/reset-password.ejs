<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        dark: { 900: '#0a0a0a', 800: '#111111', 700: '#1a1a1a', 600: '#242424', 500: '#2d2d2d', 400: '#3d3d3d', 300: '#525252', 200: '#737373', 100: '#a3a3a3' }
                    }
                }
            }
        }
    </script>
    <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
    <style>
        * { font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif; }
        .input-field { background: #1a1a1a; border: 1px solid #3d3d3d; color: #fff; }
        .input-field:focus { border-color: #525252; outline: none; box-shadow: 0 0 0 2px rgba(255,255,255,0.1); }
        .input-field::placeholder { color: #737373; }
    </style>
</head>
<body class="bg-dark-900 min-h-screen flex items-center justify-center p-4">
    <div class="w-full max-w-sm">
        <!-- Logo -->
        <div class="text-center mb-8">
            <div class="w-16 h-16 bg-white rounded-2xl flex items-center justify-center mx-auto mb-4">
                <i data-lucide="key" class="w-8 h-8 text-dark-900"></i>
            </div>
            <h1 class="text-2xl font-bold text-white">Reset Password</h1>
            <p class="text-dark-200 text-sm mt-1">Create a new password</p>
        </div>

        <!-- Card -->
        <div class="bg-dark-800 border border-dark-600 rounded-xl p-6">
            <% if (error) { %>
            <div class="mb-6 p-3 bg-red-500/10 border border-red-500/30 rounded-lg flex items-center">
                <i data-lucide="alert-circle" class="w-4 h-4 text-red-400 mr-2 flex-shrink-0"></i>
                <span class="text-red-400 text-sm"><%= error %></span>
            </div>
            <% } %>
            
            <% if (success) { %>
            <div class="mb-6 p-3 bg-green-500/10 border border-green-500/30 rounded-lg flex items-center">
                <i data-lucide="check-circle" class="w-4 h-4 text-green-400 mr-2 flex-shrink-0"></i>
                <span class="text-green-400 text-sm"><%= success %></span>
            </div>
            <div class="mt-4 text-center">
                <a href="/admin/login" class="text-white hover:text-gray-300 text-sm font-medium flex items-center justify-center transition-colors">
                    <i data-lucide="log-in" class="w-4 h-4 mr-2"></i>
                    Go to Login
                </a>
            </div>
            <% } else if (token) { %>
            <form method="POST" action="/admin/reset-password/<%= token %>" class="space-y-4">
                <div>
                    <label for="password" class="block text-sm font-medium text-dark-100 mb-2">New Password</label>
                    <input type="password" id="password" name="password" required minlength="6"
                           class="input-field w-full px-4 py-3 rounded-lg text-sm"
                           placeholder="••••••••">
                </div>
                
                <div>
                    <label for="confirmPassword" class="block text-sm font-medium text-dark-100 mb-2">Confirm Password</label>
                    <input type="password" id="confirmPassword" name="confirmPassword" required minlength="6"
                           class="input-field w-full px-4 py-3 rounded-lg text-sm"
                           placeholder="••••••••">
                </div>
                
                <button type="submit" class="w-full bg-white hover:bg-gray-200 text-dark-900 py-3 px-4 rounded-lg font-medium text-sm transition-colors flex items-center justify-center mt-6">
                    <i data-lucide="check" class="w-4 h-4 mr-2"></i>
                    Reset Password
                </button>
            </form>
            <% } else { %>
            <div class="text-center">
                <p class="text-dark-200 mb-4">This reset link is invalid or has expired.</p>
                <a href="/admin/forgot-password" class="text-white hover:text-gray-300 text-sm font-medium">Request a new link</a>
            </div>
            <% } %>
            
            <div class="mt-6 pt-6 border-t border-dark-600 text-center">
                <a href="/admin/login" class="text-dark-200 hover:text-white text-sm flex items-center justify-center transition-colors">
                    <i data-lucide="arrow-left" class="w-4 h-4 mr-2"></i>
                    Back to Login
                </a>
            </div>
        </div>
        
        <p class="text-center text-dark-300 text-xs mt-6">
            © <%= new Date().getFullYear() %> Kohinoor Gemstone
        </p>
    </div>
    
    <script>lucide.createIcons();</script>
</body>
</html>
