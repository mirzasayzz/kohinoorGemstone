<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
    <style>
        * { font-family: 'Segoe UI', system-ui, sans-serif; }
        body { background: linear-gradient(135deg, #0f2027, #203a43, #2c5364); }
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: #0f2027; }
        ::-webkit-scrollbar-thumb { background: #d4af37; border-radius: 3px; }
        .sidebar { background: linear-gradient(180deg, #0f2027, #0a1a1f); }
        .nav-link { transition: all 0.2s ease; border-left: 3px solid transparent; }
        .nav-link:hover, .nav-link.active { background: rgba(212, 175, 55, 0.1); border-left-color: #d4af37; }
        .card { background: rgba(15, 32, 39, 0.8); border: 1px solid rgba(212, 175, 55, 0.15); border-radius: 12px; }
        .text-gold { color: #d4af37; }
        .border-gold { border-color: rgba(212, 175, 55, 0.3); }
        .btn-gold { background: linear-gradient(135deg, #d4af37, #c9a227); color: #0f2027; }
        .btn-gold:hover { transform: translateY(-2px); box-shadow: 0 10px 25px rgba(212, 175, 55, 0.3); }
        .input-glow { background: rgba(32, 58, 67, 0.6); border: 1px solid rgba(212, 175, 55, 0.2); color: #fff; transition: all 0.3s ease; }
        .input-glow:hover { border-color: rgba(212, 175, 55, 0.5); box-shadow: 0 0 15px rgba(212, 175, 55, 0.2); }
        .input-glow:focus { outline: none; border-color: #d4af37; box-shadow: 0 0 20px rgba(212, 175, 55, 0.4); }
        .kingdom-title { background: linear-gradient(90deg, #d4af37, #f4d03f, #d4af37); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; animation: shimmer 3s infinite; background-size: 200% auto; }
        @keyframes shimmer { 0%,100% { background-position: 0% center; } 50% { background-position: 200% center; } }
        .section-title { color: #d4af37; font-size: 14px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; display: flex; align-items: center; gap: 10px; margin-bottom: 20px; padding-bottom: 10px; border-bottom: 1px solid rgba(212, 175, 55, 0.2); }
        .upload-zone { border: 2px dashed rgba(212, 175, 55, 0.3); transition: all 0.3s ease; }
        .upload-zone:hover { border-color: #d4af37; background: rgba(212, 175, 55, 0.05); }
        .image-checkbox { appearance: none; width: 24px; height: 24px; border: 2px solid #d4af37; border-radius: 6px; cursor: pointer; position: relative; }
        .image-checkbox:checked { background: #d4af37; }
        .image-checkbox:checked::after { content: '✓'; position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); color: #0f2027; font-weight: bold; }
    </style>
</head>
<body class="text-white min-h-screen">
    <% const activePage = 'edit-gemstone'; %>
    <%- include('partials/sidebar') %>

    <div class="lg:ml-64 min-h-screen">
        <header class="sticky top-0 z-30 h-16 bg-[#0f2027]/95 backdrop-blur border-b border-gold px-4">
            <div class="h-full flex items-center justify-between">
                <div class="flex items-center space-x-2 sm:space-x-4 min-w-0">
                    <button onclick="toggleSidebar()" class="lg:hidden p-2 hover:bg-white/10 rounded flex-shrink-0">
                        <i data-lucide="menu" class="w-5 h-5"></i>
                    </button>
                    <a href="/admin/gemstones" class="p-2 hover:bg-gold/20 rounded-lg text-gold flex-shrink-0">
                        <i data-lucide="arrow-left" class="w-5 h-5"></i>
                    </a>
                    <h1 class="text-base sm:text-lg font-semibold truncate">Edit Gemstone</h1>
                </div>
                <button type="submit" form="gemstoneForm" class="btn-gold flex items-center px-3 py-2 rounded-lg text-xs sm:text-sm font-medium transition-all flex-shrink-0">
                    <i data-lucide="save" class="w-4 h-4 sm:mr-1"></i><span class="hidden sm:inline">Save</span>
                </button>
            </div>
        </header>

        <main class="p-4 lg:p-6">
            <% if (typeof error !== 'undefined' && error) { %>
            <div class="mb-6 p-4 bg-red-500/10 border border-red-500/30 rounded-lg">
                <div class="flex items-start">
                    <i data-lucide="alert-circle" class="w-5 h-5 text-red-400 mr-3 mt-0.5 flex-shrink-0"></i>
                    <div class="text-red-400 text-sm whitespace-pre-line"><%= error %></div>
                </div>
                <% if (typeof fieldErrors !== 'undefined' && Object.keys(fieldErrors).length > 0) { %>
                <div class="mt-3 pt-3 border-t border-red-500/20">
                    <p class="text-red-300 text-xs font-medium mb-2">Fields with errors:</p>
                    <div class="flex flex-wrap gap-2">
                        <% Object.keys(fieldErrors).forEach(field => { %>
                        <span class="px-2 py-1 bg-red-500/20 text-red-300 text-xs rounded"><%= field %></span>
                        <% }); %>
                    </div>
                </div>
                <% } %>
            </div>
            <% } %>
            <% if (typeof success !== 'undefined' && success) { %>
            <div class="mb-6 p-4 bg-green-500/10 border border-green-500/30 rounded-lg flex items-center">
                <i data-lucide="check-circle" class="w-5 h-5 text-green-400 mr-3"></i>
                <span class="text-green-400"><%= success %></span>
            </div>
            <% } %>

            <form method="POST" action="/admin/gemstones/edit/<%= gemstone._id %>" enctype="multipart/form-data" id="gemstoneForm" class="max-w-4xl space-y-6">

                <!-- Basic Info -->
                <div class="card p-6">
                    <div class="section-title"><i data-lucide="info" class="w-4 h-4"></i>Basic Information</div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm text-gray-300 mb-2">Name (English) *</label>
                            <input type="text" name="name" value="<%= gemstone.name?.english || '' %>" required class="input-glow w-full px-4 py-3 rounded-lg text-sm" placeholder="e.g. Ruby">
                        </div>
                        <div>
                            <label class="block text-sm text-gray-300 mb-2">Name (Urdu)</label>
                            <input type="text" name="urduName" value="<%= gemstone.name?.urdu || '' %>" class="input-glow w-full px-4 py-3 rounded-lg text-sm" placeholder="e.g. یاقوت">
                        </div>
                        <div>
                            <label class="block text-sm text-gray-300 mb-2">Category *</label>
                            <select name="category" required onchange="toggleCustomCategory(this)" class="input-glow w-full px-4 py-3 rounded-lg text-sm">
                                <option value="">Select Category</option>
                                <% categories.forEach(cat => { %>
                                <option value="<%= cat.value %>" <%= gemstone.category === cat.value ? 'selected' : '' %>><%= cat.label %></option>
                                <% }); %>
                            </select>
                        </div>
                        <div id="customCategoryDiv" class="<%= gemstone.category === 'Other' ? '' : 'hidden' %>">
                            <label class="block text-sm text-gray-300 mb-2">Custom Category</label>
                            <input type="text" name="customCategory" value="<%= gemstone.customCategory || '' %>" class="input-glow w-full px-4 py-3 rounded-lg text-sm" placeholder="Enter type">
                        </div>
                        <div>
                            <label class="block text-sm text-gray-300 mb-2">Color *</label>
                            <input type="text" name="color" value="<%= gemstone.color || '' %>" required class="input-glow w-full px-4 py-3 rounded-lg text-sm" placeholder="e.g. Deep Red">
                        </div>
                    </div>
                </div>

                <!-- Price & Weight -->
                <div class="card p-6">
                    <div class="section-title"><i data-lucide="indian-rupee" class="w-4 h-4"></i>Price & Weight</div>
                    <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
                        <div>
                            <label class="block text-sm text-gray-300 mb-2">Min Price (₹)</label>
                            <input type="number" name="priceMin" value="<%= gemstone.priceRange?.min || gemstone.price || '' %>" class="input-glow w-full px-4 py-3 rounded-lg text-sm" placeholder="e.g. 5000">
                        </div>
                        <div>
                            <label class="block text-sm text-gray-300 mb-2">Max Price (₹)</label>
                            <input type="number" name="priceMax" value="<%= gemstone.priceRange?.max || '' %>" class="input-glow w-full px-4 py-3 rounded-lg text-sm" placeholder="e.g. 15000">
                        </div>
                        <div>
                            <label class="block text-sm text-gray-300 mb-2">Weight (Ratti)</label>
                            <input type="number" step="0.01" name="ratti" value="<%= gemstone.ratti || '' %>" class="input-glow w-full px-4 py-3 rounded-lg text-sm" placeholder="e.g. 5.25">
                        </div>
                        <div>
                            <label class="block text-sm text-gray-300 mb-2">Letter (A-Z)</label>
                            <input type="text" name="letter" value="<%= gemstone.letter || '' %>" maxlength="1" class="input-glow w-full px-4 py-3 rounded-lg text-sm uppercase" placeholder="e.g. A">
                            <p class="text-xs text-gray-500 mt-1">For alphabetical search</p>
                        </div>
                    </div>
                </div>

                <!-- Discount / Offer Price -->
                <div class="card p-6">
                    <div class="section-title"><i data-lucide="percent" class="w-4 h-4"></i>Offer Price / Discount</div>
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                        <div>
                            <label class="block text-sm text-gray-300 mb-2">Discount %</label>
                            <input type="number" name="discountPercentage" value="<%= gemstone.discount?.percentage || 0 %>" min="0" max="100" class="input-glow w-full px-4 py-3 rounded-lg text-sm" placeholder="e.g. 10">
                        </div>
                        <div>
                            <label class="block text-sm text-gray-300 mb-2">Offer Message</label>
                            <input type="text" name="discountMessage" value="<%= gemstone.discount?.message || 'Special Offer!' %>" class="input-glow w-full px-4 py-3 rounded-lg text-sm" placeholder="e.g. Limited Time Offer!">
                        </div>
                        <div class="flex items-end">
                            <label class="flex items-center space-x-3 cursor-pointer p-3 hover:bg-gold/5 rounded-lg transition-colors">
                                <input type="checkbox" name="discountActive" <%= gemstone.discount?.isActive ? 'checked' : '' %> class="w-5 h-5 rounded accent-yellow-500">
                                <span class="text-sm">Show Offer Badge</span>
                            </label>
                        </div>
                    </div>
                </div>

                <!-- Certification (Optional) -->
                <div class="card p-6">
                    <div class="section-title"><i data-lucide="award" class="w-4 h-4"></i>Certification (Optional)</div>
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                        <div class="flex items-center">
                            <label class="flex items-center space-x-3 cursor-pointer p-3 hover:bg-gold/5 rounded-lg transition-colors">
                                <input type="checkbox" name="certified" id="certifiedCheckbox" <%= gemstone.certification?.certified ? 'checked' : '' %> class="w-5 h-5 rounded accent-yellow-500" onchange="toggleCertFields()">
                                <span class="text-sm">Is Certified?</span>
                            </label>
                        </div>
                        <div id="certNumberField">
                            <label class="block text-sm text-gray-300 mb-2">Certificate Number</label>
                            <input type="text" name="certificateNumber" value="<%= gemstone.certification?.certificateNumber || '' %>" class="input-glow w-full px-4 py-3 rounded-lg text-sm" placeholder="e.g. JGGTL308258">
                        </div>
                        <div id="certBodyField">
                            <label class="block text-sm text-gray-300 mb-2">Certifying Body</label>
                            <input type="text" name="certifyingBody" value="<%= gemstone.certification?.certifyingBody || '' %>" class="input-glow w-full px-4 py-3 rounded-lg text-sm" placeholder="e.g. JG Gems Testing Lab">
                        </div>
                    </div>
                    
                    <!-- Certificate Image Upload -->
                    <div id="certImageField" class="mt-4">
                        <label class="block text-sm text-gray-300 mb-2">Certificate Image (Optional)</label>
                        <!-- Hidden input for delete flag - must be outside conditional -->
                        <input type="hidden" name="deleteCertImage" id="deleteCertImageInput" value="">
                        <div class="flex items-start gap-4">
                            <% if (gemstone.certification?.certificationImage?.url) { %>
                            <div id="currentCertImage" style="position: relative;">
                                <img src="<%= gemstone.certification.certificationImage.url %>" alt="Current Certificate" style="width: 128px; height: 96px; object-fit: cover; border-radius: 8px; border: 1px solid rgba(212,175,55,0.3);">
                                <div id="certImageOverlay" style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.7); border-radius: 8px; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 4px;">
                                    <span style="color: white; font-size: 11px;">Current</span>
                                    <span id="deleteBtn" style="background: #ef4444; color: white; font-size: 11px; padding: 4px 8px; border-radius: 4px; cursor: pointer;" onclick="document.getElementById('deleteCertImageInput').value='true'; this.innerText='MARKED FOR DELETE'; this.style.background='#991b1b'; alert('Will be deleted on save!');">
                                        🗑️ Delete
                                    </span>
                                </div>
                            </div>
                            <% } %>
                            <div class="flex-1">
                                <div class="upload-zone rounded-xl p-4 text-center cursor-pointer border-2 border-dashed border-gold/30 hover:border-gold/60 transition-colors" onclick="document.getElementById('certificationImage').click()">
                                    <input type="file" id="certificationImage" name="certificationImage" accept="image/*" class="hidden" onchange="previewCertImage(this)">
                                    <i data-lucide="upload-cloud" class="w-6 h-6 text-gold mx-auto mb-2"></i>
                                    <p class="text-gray-300 text-xs mb-1"><%= gemstone.certification?.certificationImage?.url ? 'Replace certificate' : 'Upload certificate' %></p>
                                    <p class="text-xs text-gray-500">PNG, JPG up to 10MB</p>
                                </div>
                            </div>
                            <div id="certImagePreview" class="hidden">
                                <img id="certPreviewImg" src="" alt="Preview" class="w-32 h-24 object-cover rounded-lg border border-gold/30">
                            </div>
                        </div>
                    </div>
                    
                    <p class="text-xs text-gray-500 mt-3">Leave unchecked if gemstone is not certified. Certificate details are optional.</p>
                </div>

                <!-- Description -->
                <div class="card p-6">
                    <div class="section-title"><i data-lucide="file-text" class="w-4 h-4"></i>Description</div>
                    <div class="space-y-4">
                        <div>
                            <label class="block text-sm text-gray-300 mb-2">Summary *</label>
                            <textarea name="summary" required rows="2" class="input-glow w-full px-4 py-3 rounded-lg text-sm" placeholder="Short description..."><%= gemstone.summary || '' %></textarea>
                        </div>
                        <div>
                            <label class="block text-sm text-gray-300 mb-2">Full Description *</label>
                            <textarea name="description" required rows="4" class="input-glow w-full px-4 py-3 rounded-lg text-sm" placeholder="Detailed description..."><%= gemstone.description || '' %></textarea>
                        </div>
                    </div>
                </div>

                <!-- Current Images -->
                <% if (gemstone.images && gemstone.images.length > 0) { %>
                <div class="card p-6">
                    <div class="section-title"><i data-lucide="images" class="w-4 h-4"></i>Current Images</div>
                    <p class="text-sm text-gray-400 mb-4">Click <span class="text-red-400">✕ Delete</span> button to remove image</p>
                    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4" id="currentImagesGrid">
                        <% gemstone.images.forEach((img, i) => { %>
                        <div class="relative group image-item" id="image-<%= i %>">
                            <div class="aspect-square rounded-xl overflow-hidden bg-[#1a3a47] border-2 border-gold/20 transition-all">
                                <img src="<%= img.url %>" class="w-full h-full object-cover">
                            </div>
                            <!-- Hidden checkbox to track kept images -->
                            <input type="checkbox" name="keepImages" value="<%= img.publicId %>" checked class="hidden image-keep-checkbox" id="keep-<%= i %>">
                            <!-- Delete button -->
                            <button type="button" onclick="toggleImageDelete(<%= i %>)" class="absolute top-2 right-2 bg-red-500 hover:bg-red-600 text-white px-2 py-1 rounded-lg text-xs font-medium flex items-center gap-1 transition-all delete-btn">
                                <i data-lucide="x" class="w-3 h-3"></i>
                                <span>Delete</span>
                            </button>
                            <!-- Restore button (hidden initially) -->
                            <button type="button" onclick="toggleImageDelete(<%= i %>)" class="absolute top-2 right-2 bg-green-500 hover:bg-green-600 text-white px-2 py-1 rounded-lg text-xs font-medium flex items-center gap-1 transition-all restore-btn hidden">
                                <i data-lucide="undo" class="w-3 h-3"></i>
                                <span>Restore</span>
                            </button>
                            <div class="absolute bottom-2 left-2 px-2 py-1 bg-black/70 rounded text-xs text-gold">
                                Image <%= i + 1 %>
                            </div>
                            <!-- Deleted overlay -->
                            <div class="absolute inset-0 bg-red-900/80 rounded-xl flex items-center justify-center deleted-overlay hidden">
                                <span class="text-white font-bold text-sm">WILL BE DELETED</span>
                            </div>
                        </div>
                        <% }); %>
                    </div>
                </div>
                <% } %>

                <!-- Upload New Images -->
                <div class="card p-6">
                    <div class="section-title"><i data-lucide="upload" class="w-4 h-4"></i>Add New Images</div>
                    <div class="upload-zone rounded-xl p-8 text-center cursor-pointer" onclick="document.getElementById('images').click()">
                        <input type="file" id="images" name="images" multiple accept="image/*" class="hidden" onchange="previewImages(this)">
                        <i data-lucide="upload-cloud" class="w-12 h-12 text-gold mx-auto mb-3"></i>
                        <p class="text-gray-300 mb-1">Click to upload</p>
                        <p class="text-xs text-gray-500">PNG, JPG up to 10MB</p>
                    </div>
                    <div id="previewContainer" class="mt-4 grid grid-cols-3 sm:grid-cols-4 lg:grid-cols-6 gap-3"></div>
                </div>

                <!-- Settings -->
                <div class="card p-6">
                    <div class="section-title"><i data-lucide="settings" class="w-4 h-4"></i>Settings</div>
                    <div class="space-y-3">
                        <label class="flex items-center space-x-3 cursor-pointer p-3 hover:bg-gold/5 rounded-lg transition-colors">
                            <input type="checkbox" name="isTrending" <%= gemstone.trending ? 'checked' : '' %> class="w-5 h-5 rounded accent-yellow-500">
                            <span class="text-sm">Mark as Trending</span>
                        </label>
                        <label class="flex items-center space-x-3 cursor-pointer p-3 hover:bg-gold/5 rounded-lg transition-colors">
                            <input type="checkbox" name="isActive" <%= gemstone.isActive !== false ? 'checked' : '' %> class="w-5 h-5 rounded accent-yellow-500">
                            <span class="text-sm">Active (visible on website)</span>
                        </label>
                    </div>
                </div>

                <!-- Submit -->
                <div class="flex gap-3">
                    <a href="/admin/gemstones" class="flex-1 px-6 py-3 bg-white/10 hover:bg-white/20 rounded-lg text-center text-sm transition-colors">Cancel</a>
                    <button type="submit" class="btn-gold flex-1 px-6 py-3 rounded-lg font-medium text-sm transition-all flex items-center justify-center">
                        <i data-lucide="save" class="w-4 h-4 mr-2"></i>Update Gemstone
                    </button>
                </div>
            </form>
        </main>
    </div>

    <script>
        lucide.createIcons();
        
        function toggleSidebar() {
            document.getElementById('sidebar').classList.toggle('-translate-x-full');
            document.getElementById('overlay').classList.toggle('hidden');
        }

        function toggleCustomCategory(select) {
            const div = document.getElementById('customCategoryDiv');
            if (select.value === 'Other') {
                div.classList.remove('hidden');
            } else {
                div.classList.add('hidden');
            }
        }

        function previewImages(input) {
            const container = document.getElementById('previewContainer');
            container.innerHTML = '';
            
            if (input.files) {
                Array.from(input.files).forEach((file, i) => {
                    const reader = new FileReader();
                    reader.onload = function(e) {
                        const div = document.createElement('div');
                        div.className = 'relative aspect-square rounded-lg overflow-hidden bg-[#1a3a47] border border-gold/30';
                        div.innerHTML = '<img src="' + e.target.result + '" class="w-full h-full object-cover"><div class="absolute bottom-1 left-1 px-1.5 py-0.5 bg-black/70 rounded text-xs text-gold">New ' + (i+1) + '</div>';
                        container.appendChild(div);
                    };
                    reader.readAsDataURL(file);
                });
            }
        }

        function toggleCertFields() {
            // All certification fields are now always visible (independent)
            // This function kept for compatibility but no longer hides fields
        }
        
        function previewCertImage(input) {
            const preview = document.getElementById('certImagePreview');
            const previewImg = document.getElementById('certPreviewImg');
            
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    previewImg.src = e.target.result;
                    preview.classList.remove('hidden');
                };
                reader.readAsDataURL(input.files[0]);
            } else {
                preview.classList.add('hidden');
            }
        }
        
        function deleteCertImage() {
            console.log('Delete button clicked!');
            
            var deleteInput = document.getElementById('deleteCertImageInput');
            var currentImg = document.getElementById('currentCertImage');
            var overlay = document.getElementById('certImageOverlay');
            
            if (deleteInput) {
                deleteInput.value = 'true';
                console.log('Delete flag set to: true');
            } else {
                console.error('Delete input not found!');
                return;
            }
            
            if (currentImg) {
                currentImg.style.opacity = '0.3';
                currentImg.style.border = '2px solid red';
            }
            
            if (overlay) {
                overlay.innerHTML = '<span class="text-red-500 text-sm font-bold">⚠️ WILL BE DELETED</span><br><span class="text-xs text-gray-300">Save to confirm</span>';
                overlay.style.background = 'rgba(0,0,0,0.8)';
            }
            
            alert('Certificate image marked for deletion. Click SAVE to confirm.');
        }

        // Toggle image delete state
        function toggleImageDelete(index) {
            const imageItem = document.getElementById('image-' + index);
            const keepCheckbox = document.getElementById('keep-' + index);
            const deleteBtn = imageItem.querySelector('.delete-btn');
            const restoreBtn = imageItem.querySelector('.restore-btn');
            const overlay = imageItem.querySelector('.deleted-overlay');
            
            if (keepCheckbox.checked) {
                // Mark for deletion
                keepCheckbox.checked = false;
                deleteBtn.classList.add('hidden');
                restoreBtn.classList.remove('hidden');
                overlay.classList.remove('hidden');
                imageItem.querySelector('.aspect-square').classList.add('opacity-50');
            } else {
                // Restore image
                keepCheckbox.checked = true;
                deleteBtn.classList.remove('hidden');
                restoreBtn.classList.add('hidden');
                overlay.classList.add('hidden');
                imageItem.querySelector('.aspect-square').classList.remove('opacity-50');
            }
            
            // Re-initialize lucide icons
            lucide.createIcons();
        }
    </script>
</body>
</html>
