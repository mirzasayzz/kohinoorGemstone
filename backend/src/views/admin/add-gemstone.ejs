<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
    <style>
        * { font-family: 'Segoe UI', system-ui, sans-serif; }
        body { background: linear-gradient(135deg, #0f2027, #203a43, #2c5364); }
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: #0f2027; }
        ::-webkit-scrollbar-thumb { background: #d4af37; border-radius: 3px; }
        .sidebar { background: linear-gradient(180deg, #0f2027, #0a1a1f); }
        .nav-link { transition: all 0.2s ease; border-left: 3px solid transparent; }
        .nav-link:hover, .nav-link.active { background: rgba(212, 175, 55, 0.1); border-left-color: #d4af37; }
        .card { background: rgba(15, 32, 39, 0.8); border: 1px solid rgba(212, 175, 55, 0.15); border-radius: 12px; }
        .text-gold { color: #d4af37; }
        .border-gold { border-color: rgba(212, 175, 55, 0.3); }
        .btn-gold { background: linear-gradient(135deg, #d4af37, #c9a227); color: #0f2027; }
        .btn-gold:hover { transform: translateY(-2px); box-shadow: 0 10px 25px rgba(212, 175, 55, 0.3); }
        .input-glow { background: rgba(32, 58, 67, 0.6); border: 1px solid rgba(212, 175, 55, 0.2); color: #fff; transition: all 0.3s ease; }
        .input-glow:hover { border-color: rgba(212, 175, 55, 0.5); box-shadow: 0 0 15px rgba(212, 175, 55, 0.2); }
        .input-glow:focus { outline: none; border-color: #d4af37; box-shadow: 0 0 20px rgba(212, 175, 55, 0.4); }
        .kingdom-title { background: linear-gradient(90deg, #d4af37, #f4d03f, #d4af37); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; }
        .section-title { color: #d4af37; font-size: 14px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; display: flex; align-items: center; gap: 10px; margin-bottom: 20px; padding-bottom: 10px; border-bottom: 1px solid rgba(212, 175, 55, 0.2); }
        .upload-zone { border: 2px dashed rgba(212, 175, 55, 0.3); transition: all 0.3s ease; }
        .upload-zone:hover { border-color: #d4af37; background: rgba(212, 175, 55, 0.05); }
    </style>
</head>
<body class="text-white min-h-screen">
    <% const activePage = 'add-gemstone'; %>
    <%- include('partials/sidebar') %>

    <div class="lg:ml-64 min-h-screen">
        <header class="sticky top-0 z-30 h-16 bg-[#0f2027]/95 backdrop-blur border-b border-gold px-4">
            <div class="h-full flex items-center justify-between">
                <div class="flex items-center space-x-2 sm:space-x-4 min-w-0">
                    <button onclick="toggleSidebar()" class="lg:hidden p-2 hover:bg-white/10 rounded flex-shrink-0">
                        <i data-lucide="menu" class="w-5 h-5"></i>
                    </button>
                    <a href="/admin/gemstones" class="p-2 hover:bg-gold/20 rounded-lg text-gold flex-shrink-0">
                        <i data-lucide="arrow-left" class="w-5 h-5"></i>
                    </a>
                    <h1 class="text-base sm:text-lg font-semibold truncate">Add Gemstone</h1>
                </div>
                <button type="submit" form="gemstoneForm" class="btn-gold flex items-center px-3 py-2 rounded-lg text-xs sm:text-sm font-medium transition-all flex-shrink-0">
                    <i data-lucide="save" class="w-4 h-4 sm:mr-1"></i><span class="hidden sm:inline">Save</span>
                </button>
            </div>
        </header>

        <main class="p-4 lg:p-6">
            <% if (typeof error !== 'undefined' && error) { %>
            <div class="mb-6 p-4 bg-red-500/10 border border-red-500/30 rounded-lg flex items-center">
                <i data-lucide="alert-circle" class="w-5 h-5 text-red-400 mr-3"></i>
                <span class="text-red-400"><%= error %></span>
            </div>
            <% } %>

            <form method="POST" action="/admin/gemstones/add" enctype="multipart/form-data" id="gemstoneForm" class="max-w-4xl space-y-6">

                <!-- Basic Info -->
                <div class="card p-4 sm:p-6">
                    <div class="section-title"><i data-lucide="info" class="w-4 h-4"></i>Basic Information</div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm text-gray-300 mb-2">Name (English) *</label>
                            <input type="text" name="name" required class="input-glow w-full px-4 py-3 rounded-lg text-sm" placeholder="e.g. Ruby">
                        </div>
                        <div>
                            <label class="block text-sm text-gray-300 mb-2">Name (Urdu)</label>
                            <input type="text" name="urduName" class="input-glow w-full px-4 py-3 rounded-lg text-sm" placeholder="e.g. یاقوت">
                        </div>
                        <div>
                            <label class="block text-sm text-gray-300 mb-2">Category *</label>
                            <select name="category" required onchange="toggleCustomCategory(this)" class="input-glow w-full px-4 py-3 rounded-lg text-sm">
                                <option value="">Select Category</option>
                                <% categories.forEach(cat => { %>
                                <option value="<%= cat.value %>"><%= cat.label %></option>
                                <% }); %>
                            </select>
                        </div>
                        <div id="customCategoryDiv" class="hidden">
                            <label class="block text-sm text-gray-300 mb-2">Custom Category</label>
                            <input type="text" name="customCategory" class="input-glow w-full px-4 py-3 rounded-lg text-sm" placeholder="Enter type">
                        </div>
                        <div>
                            <label class="block text-sm text-gray-300 mb-2">Color *</label>
                            <input type="text" name="color" required class="input-glow w-full px-4 py-3 rounded-lg text-sm" placeholder="e.g. Deep Red">
                        </div>
                    </div>
                </div>

                <!-- Price & Weight -->
                <div class="card p-6">
                    <div class="section-title"><i data-lucide="indian-rupee" class="w-4 h-4"></i>Price & Weight</div>
                    <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
                        <div>
                            <label class="block text-sm text-gray-300 mb-2">Min Price (₹)</label>
                            <input type="number" name="priceMin" class="input-glow w-full px-4 py-3 rounded-lg text-sm" placeholder="e.g. 5000">
                        </div>
                        <div>
                            <label class="block text-sm text-gray-300 mb-2">Max Price (₹)</label>
                            <input type="number" name="priceMax" class="input-glow w-full px-4 py-3 rounded-lg text-sm" placeholder="e.g. 15000">
                        </div>
                        <div>
                            <label class="block text-sm text-gray-300 mb-2">Weight (Ratti)</label>
                            <input type="number" step="0.01" name="ratti" class="input-glow w-full px-4 py-3 rounded-lg text-sm" placeholder="e.g. 5.25">
                        </div>
                        <div>
                            <label class="block text-sm text-gray-300 mb-2">Letter (A-Z)</label>
                            <input type="text" name="letter" maxlength="1" class="input-glow w-full px-4 py-3 rounded-lg text-sm uppercase" placeholder="e.g. A">
                            <p class="text-xs text-gray-500 mt-1">For alphabetical search</p>
                        </div>
                    </div>
                </div>

                <!-- Discount / Offer Price -->
                <div class="card p-6">
                    <div class="section-title"><i data-lucide="percent" class="w-4 h-4"></i>Offer Price / Discount (Optional)</div>
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                        <div>
                            <label class="block text-sm text-gray-300 mb-2">Discount %</label>
                            <input type="number" name="discountPercentage" value="0" min="0" max="100" class="input-glow w-full px-4 py-3 rounded-lg text-sm" placeholder="e.g. 10">
                        </div>
                        <div>
                            <label class="block text-sm text-gray-300 mb-2">Offer Message</label>
                            <input type="text" name="discountMessage" value="Special Offer!" class="input-glow w-full px-4 py-3 rounded-lg text-sm" placeholder="e.g. Limited Time Offer!">
                        </div>
                        <div class="flex items-end">
                            <label class="flex items-center space-x-3 cursor-pointer p-3 hover:bg-gold/5 rounded-lg transition-colors">
                                <input type="checkbox" name="discountActive" class="w-5 h-5 rounded accent-yellow-500">
                                <span class="text-sm">Show Offer Badge</span>
                            </label>
                        </div>
                    </div>
                </div>

                <!-- Certification (Optional) -->
                <div class="card p-6">
                    <div class="section-title"><i data-lucide="award" class="w-4 h-4"></i>Certification (Optional)</div>
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                        <div class="flex items-center">
                            <label class="flex items-center space-x-3 cursor-pointer p-3 hover:bg-gold/5 rounded-lg transition-colors">
                                <input type="checkbox" name="certified" id="certifiedCheckbox" class="w-5 h-5 rounded accent-yellow-500" onchange="toggleCertFields()">
                                <span class="text-sm">Is Certified?</span>
                            </label>
                        </div>
                        <div id="certNumberField">
                            <label class="block text-sm text-gray-300 mb-2">Certificate Number</label>
                            <input type="text" name="certificateNumber" class="input-glow w-full px-4 py-3 rounded-lg text-sm" placeholder="e.g. JGGTL308258">
                        </div>
                        <div id="certBodyField">
                            <label class="block text-sm text-gray-300 mb-2">Certifying Body</label>
                            <input type="text" name="certifyingBody" class="input-glow w-full px-4 py-3 rounded-lg text-sm" placeholder="e.g. JG Gems Testing Lab">
                        </div>
                    </div>
                    
                    <!-- Certificate Image Upload -->
                    <div id="certImageField" class="mt-4">
                        <label class="block text-sm text-gray-300 mb-2">Certificate Image (Optional)</label>
                        <div class="flex items-start gap-4">
                            <div class="flex-1">
                                <div class="upload-zone rounded-xl p-4 text-center cursor-pointer border-2 border-dashed border-gold/30 hover:border-gold/60 transition-colors" onclick="document.getElementById('certificationImage').click()">
                                    <input type="file" id="certificationImage" name="certificationImage" accept="image/*" class="hidden" onchange="previewCertImage(this)">
                                    <i data-lucide="upload-cloud" class="w-6 h-6 text-gold mx-auto mb-2"></i>
                                    <p class="text-gray-300 text-xs mb-1">Upload certificate</p>
                                    <p class="text-xs text-gray-500">PNG, JPG up to 10MB</p>
                                </div>
                            </div>
                            <div id="certImagePreview" class="hidden">
                                <img id="certPreviewImg" src="" alt="Preview" class="w-32 h-24 object-cover rounded-lg border border-gold/30">
                            </div>
                        </div>
                    </div>
                    
                    <p class="text-xs text-gray-500 mt-3">Leave unchecked if gemstone is not certified. Certificate details are optional.</p>
                </div>

                <!-- Description -->
                <div class="card p-6">
                    <div class="section-title"><i data-lucide="file-text" class="w-4 h-4"></i>Description</div>
                    <div class="space-y-4">
                        <div>
                            <label class="block text-sm text-gray-300 mb-2">Summary *</label>
                            <textarea name="summary" required rows="2" class="input-glow w-full px-4 py-3 rounded-lg text-sm" placeholder="Short description..."></textarea>
                        </div>
                        <div>
                            <label class="block text-sm text-gray-300 mb-2">Full Description *</label>
                            <textarea name="description" required rows="4" class="input-glow w-full px-4 py-3 rounded-lg text-sm" placeholder="Detailed description..."></textarea>
                        </div>
                    </div>
                </div>

                <!-- Upload Images -->
                <div class="card p-6">
                    <div class="section-title"><i data-lucide="image" class="w-4 h-4"></i>Images *</div>
                    <div class="upload-zone rounded-xl p-8 text-center cursor-pointer" onclick="document.getElementById('images').click()">
                        <input type="file" id="images" name="images" multiple accept="image/*" required class="hidden" onchange="previewImages(this)">
                        <i data-lucide="upload-cloud" class="w-12 h-12 text-gold mx-auto mb-3"></i>
                        <p class="text-gray-300 mb-1">Click to upload images</p>
                        <p class="text-xs text-gray-500">PNG, JPG up to 10MB • At least 1 image required</p>
                    </div>
                    <div id="previewContainer" class="mt-4 grid grid-cols-3 sm:grid-cols-4 lg:grid-cols-6 gap-3"></div>
                </div>

                <!-- Settings -->
                <div class="card p-6">
                    <div class="section-title"><i data-lucide="settings" class="w-4 h-4"></i>Settings</div>
                    <div class="space-y-3">
                        <label class="flex items-center space-x-3 cursor-pointer p-3 hover:bg-gold/5 rounded-lg transition-colors">
                            <input type="checkbox" name="isTrending" class="w-5 h-5 rounded accent-yellow-500">
                            <span class="text-sm">Mark as Trending</span>
                        </label>
                        <label class="flex items-center space-x-3 cursor-pointer p-3 hover:bg-gold/5 rounded-lg transition-colors">
                            <input type="checkbox" name="isActive" checked class="w-5 h-5 rounded accent-yellow-500">
                            <span class="text-sm">Active (visible on website)</span>
                        </label>
                    </div>
                </div>

                <!-- Submit -->
                <div class="flex gap-3">
                    <a href="/admin/gemstones" class="flex-1 px-6 py-3 bg-white/10 hover:bg-white/20 rounded-lg text-center text-sm transition-colors">Cancel</a>
                    <button type="submit" class="btn-gold flex-1 px-6 py-3 rounded-lg font-medium text-sm transition-all flex items-center justify-center">
                        <i data-lucide="plus" class="w-4 h-4 mr-2"></i>Add Gemstone
                    </button>
                </div>
            </form>
        </main>
    </div>

    <script>
        lucide.createIcons();
        
        function toggleSidebar() {
            document.getElementById('sidebar').classList.toggle('-translate-x-full');
            document.getElementById('overlay').classList.toggle('hidden');
        }

        function toggleCustomCategory(select) {
            const div = document.getElementById('customCategoryDiv');
            if (select.value === 'Other') {
                div.classList.remove('hidden');
            } else {
                div.classList.add('hidden');
            }
        }

        function previewImages(input) {
            const container = document.getElementById('previewContainer');
            container.innerHTML = '';
            
            if (input.files) {
                Array.from(input.files).forEach((file, i) => {
                    const reader = new FileReader();
                    reader.onload = function(e) {
                        const div = document.createElement('div');
                        div.className = 'relative aspect-square rounded-lg overflow-hidden bg-[#1a3a47] border border-gold/30';
                        div.innerHTML = '<img src="' + e.target.result + '" class="w-full h-full object-cover"><div class="absolute bottom-1 left-1 px-1.5 py-0.5 bg-black/70 rounded text-xs text-gold">' + (i+1) + '</div>';
                        container.appendChild(div);
                    };
                    reader.readAsDataURL(file);
                });
            }
        }

        function toggleCertFields() {
            // All certification fields are now always visible (independent)
            // This function kept for compatibility but no longer hides fields
        }
        
        function previewCertImage(input) {
            const preview = document.getElementById('certImagePreview');
            const previewImg = document.getElementById('certPreviewImg');
            
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    previewImg.src = e.target.result;
                    preview.classList.remove('hidden');
                };
                reader.readAsDataURL(input.files[0]);
            } else {
                preview.classList.add('hidden');
            }
        }
    </script>
</body>
</html>
