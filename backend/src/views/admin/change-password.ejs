<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
    <style>
        * { font-family: 'Segoe UI', system-ui, sans-serif; }
        body { background: linear-gradient(135deg, #0f2027, #203a43, #2c5364); }
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: #0f2027; }
        ::-webkit-scrollbar-thumb { background: #d4af37; border-radius: 3px; }
        .sidebar { background: linear-gradient(180deg, #0f2027, #0a1a1f); }
        .nav-link { transition: all 0.2s ease; border-left: 3px solid transparent; }
        .nav-link:hover, .nav-link.active { background: rgba(212, 175, 55, 0.1); border-left-color: #d4af37; }
        .card { background: rgba(15, 32, 39, 0.8); border: 1px solid rgba(212, 175, 55, 0.15); border-radius: 16px; }
        .text-gold { color: #d4af37; }
        .border-gold { border-color: rgba(212, 175, 55, 0.3); }
        .btn-gold { background: linear-gradient(135deg, #d4af37, #c9a227); color: #0f2027; }
        .btn-gold:hover { transform: translateY(-2px); box-shadow: 0 10px 25px rgba(212, 175, 55, 0.3); }
        
        /* Input with shimmer glow */
        .input-glow {
            background: rgba(32, 58, 67, 0.6);
            border: 1px solid rgba(212, 175, 55, 0.2);
            color: #fff;
            transition: all 0.3s ease;
        }
        .input-glow:hover {
            border-color: rgba(212, 175, 55, 0.5);
            box-shadow: 0 0 15px rgba(212, 175, 55, 0.2);
        }
        .input-glow:focus {
            outline: none;
            border-color: #d4af37;
            box-shadow: 0 0 20px rgba(212, 175, 55, 0.4), 0 0 40px rgba(212, 175, 55, 0.1);
            background: rgba(32, 58, 67, 0.8);
        }
        .input-glow::placeholder { color: rgba(255,255,255,0.4); }
    </style>
</head>
<body class="text-white min-h-screen">
    <% const activePage = 'change-password'; %>
    <%- include('partials/sidebar') %>

    <div class="lg:ml-64 min-h-screen">
        <header class="sticky top-0 z-30 h-16 bg-[#0f2027]/95 backdrop-blur border-b border-gold px-4">
            <div class="h-full flex items-center justify-between">
                <div class="flex items-center space-x-4">
                    <button onclick="toggleSidebar()" class="lg:hidden p-2 hover:bg-white/10 rounded">
                        <i data-lucide="menu" class="w-5 h-5"></i>
                    </button>
                    <h1 class="text-lg font-semibold">Change Password</h1>
                </div>
            </div>
        </header>

        <main class="p-4 lg:p-6 flex items-center justify-center min-h-[calc(100vh-64px)]">
            <div class="w-full max-w-md">
                <% if (error) { %>
                <div class="mb-6 p-4 bg-red-500/10 border border-red-500/30 rounded-lg flex items-center">
                    <i data-lucide="alert-circle" class="w-5 h-5 text-red-400 mr-3"></i>
                    <span class="text-red-400"><%= error %></span>
                </div>
                <% } %>
                
                <% if (success) { %>
                <div class="mb-6 p-4 bg-green-500/10 border border-green-500/30 rounded-lg flex items-center">
                    <i data-lucide="check-circle" class="w-5 h-5 text-green-400 mr-3"></i>
                    <span class="text-green-400"><%= success %></span>
                </div>
                <% } %>

                <div class="card p-8">
                    <!-- Icon -->
                    <div class="text-center mb-6">
                        <div class="w-16 h-16 bg-gradient-to-br from-yellow-500 to-yellow-600 rounded-2xl flex items-center justify-center mx-auto mb-4 shadow-lg shadow-yellow-500/20">
                            <i data-lucide="key" class="w-8 h-8 text-white"></i>
                        </div>
                        <h2 class="text-xl font-semibold text-gold">Update Password</h2>
                        <p class="text-sm text-gray-400 mt-1">Keep your account secure</p>
                    </div>
                    
                    <form method="POST" action="/admin/change-password" class="space-y-5">
                        <div>
                            <label class="block text-sm text-gray-300 mb-2">Current Password</label>
                            <input type="password" name="currentPassword" required
                                   class="input-glow w-full px-4 py-3.5 rounded-xl text-sm"
                                   placeholder="Enter current password">
                        </div>
                        
                        <div>
                            <label class="block text-sm text-gray-300 mb-2">New Password</label>
                            <input type="password" name="newPassword" required minlength="6"
                                   class="input-glow w-full px-4 py-3.5 rounded-xl text-sm"
                                   placeholder="Enter new password">
                            <p class="text-xs text-gray-500 mt-1">Minimum 6 characters</p>
                        </div>
                        
                        <div>
                            <label class="block text-sm text-gray-300 mb-2">Confirm New Password</label>
                            <input type="password" name="confirmPassword" required minlength="6"
                                   class="input-glow w-full px-4 py-3.5 rounded-xl text-sm"
                                   placeholder="Confirm new password">
                        </div>
                        
                        <button type="submit" class="btn-gold w-full py-3.5 rounded-xl font-semibold text-sm transition-all flex items-center justify-center mt-6">
                            <i data-lucide="save" class="w-4 h-4 mr-2"></i>
                            Update Password
                        </button>
                    </form>
                </div>
            </div>
        </main>
    </div>
    
    <script>
        lucide.createIcons();
        function toggleSidebar() {
            document.getElementById('sidebar').classList.toggle('-translate-x-full');
            document.getElementById('overlay').classList.toggle('hidden');
        }
    </script>
</body>
</html>
