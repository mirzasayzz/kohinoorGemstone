{
  "name": "kohinoor-gemstone",
  "version": "1.0.0",
  "description": "Kohinoor Gemstone E-commerce Platform",
  "main": "backend/src/server.js",
  "type": "module",
  "engines": {
    "node": "20.x",
    "npm": "10.x"
  },
  "scripts": {
    "start": "node backend/src/server.js",
    "postinstall": "cd backend && npm install",
    "heroku-postbuild": "cd frontend && npm install --include=dev && VITE_API_BASE_URL=/api npm run build && mkdir -p ../backend/src/public && cp -r dist/* ../backend/src/public/"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "ejs": "^3.1.9",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "multer-storage-cloudinary": "^4.0.0",
    "nodemailer": "^6.9.7",
    "slugify": "^1.6.6",
    "socket.io": "^4.7.2",
    "streamifier": "^0.1.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {},
  "keywords": ["gemstone", "ecommerce", "kohinoor"],
  "author": "Tuba Mirza",
  "license": "ISC"
}
